First thing to check

Run this to find MBIs where multiple rows share the same latest update date:

WITH BASE AS (
    SELECT
        ED.MBI,
        EE.EMAILADDRESS,
        UPPER(EE.EMAIL_INVALID_IND) AS EMAIL_INVALID_IND,
        EE.UPDATEDATE
    FROM LIG_PRD_MRCS_OH_OUTREACH_SH_DB.MRCS_OH_OUTREACH.TBL_CONTACT_EMAIL EE
    INNER JOIN LIG_PRD_MRCS_OH_OUTREACH_SH_DB.MRCS_OH_OUTREACH.TBL_DEMOGRAPHIC ED
        ON EE.ENTITY_ID = ED.ENTITY_ID
    INNER JOIN FWRB_PRD_WMIDR_DB.BI_ANALYSIS.DIM_MEMBER DM
        ON ED.MBI = DM.MEMBER_MBI
    INNER JOIN FWRB_PRD_WMIDR_DB.BI_ANALYSIS.MEMBER_REPORT_MONTH MRM
        ON DM.MEMBER_ID = MRM.MEMBER_ID
    WHERE MRM.REPORT_MONTH = (
        SELECT MAX(REPORT_MONTH)
        FROM FWRB_PRD_WMIDR_DB.BI_ANALYSIS.MEMBER_REPORT_MONTH
    )
),
MAX_DATES AS (
    SELECT
        MBI,
        MAX(UPDATEDATE) AS MAX_UPDATEDATE
    FROM BASE
    GROUP BY MBI
)
SELECT
    B.MBI,
    B.UPDATEDATE,
    COUNT(*) AS ROW_COUNT,
    COUNT(DISTINCT B.EMAIL_INVALID_IND) AS DISTINCT_STATUS_COUNT
FROM BASE B
INNER JOIN MAX_DATES M
    ON B.MBI = M.MBI
   AND B.UPDATEDATE = M.MAX_UPDATEDATE
GROUP BY B.MBI, B.UPDATEDATE
HAVING COUNT(*) > 1
ORDER BY ROW_COUNT DESC, B.MBI;

If this returns rows, then you have tied latest records.

Next, find the specific MBI that is causing the 1-row mismatch

Run this:

WITH EXPECTED AS (
    SELECT
        ED.MBI,
        CASE
            WHEN UPPER(EE.EMAIL_INVALID_IND) = 'INVALID' THEN 'INVALID'
            ELSE 'VALID'
        END AS EMAIL_STATUS,
        ROW_NUMBER() OVER (
            PARTITION BY ED.MBI
            ORDER BY EE.UPDATEDATE DESC
        ) AS RN
    FROM LIG_PRD_MRCS_OH_OUTREACH_SH_DB.MRCS_OH_OUTREACH.TBL_CONTACT_EMAIL EE
    INNER JOIN LIG_PRD_MRCS_OH_OUTREACH_SH_DB.MRCS_OH_OUTREACH.TBL_DEMOGRAPHIC ED
        ON EE.ENTITY_ID = ED.ENTITY_ID
    INNER JOIN FWRB_PRD_WMIDR_DB.BI_ANALYSIS.DIM_MEMBER DM
        ON ED.MBI = DM.MEMBER_MBI
    INNER JOIN FWRB_PRD_WMIDR_DB.BI_ANALYSIS.MEMBER_REPORT_MONTH MRM
        ON DM.MEMBER_ID = MRM.MEMBER_ID
    WHERE MRM.REPORT_MONTH = (
        SELECT MAX(REPORT_MONTH)
        FROM FWRB_PRD_WMIDR_DB.BI_ANALYSIS.MEMBER_REPORT_MONTH
    )
)
SELECT
    E.MBI,
    E.EMAIL_STATUS AS EXPECTED_STATUS,
    V.EMAIL_STATUS AS VIEW_STATUS
FROM EXPECTED E
INNER JOIN ASQN_PRD_MIGRATION_DB.DBO.VW_WM_UHC_MBR_EMAIL V
    ON E.MBI = V.MBI
WHERE E.RN = 1
  AND E.EMAIL_STATUS <> V.EMAIL_STATUS;

This should ideally show the one mismatched MBI.

