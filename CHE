Better comparison: FULL OUTER JOIN
This will show if one side has an extra row or missing row.
WITH EXPECTED AS (    SELECT        ED.MBI,        CASE            WHEN UPPER(EE.EMAIL_INVALID_IND) = 'INVALID' THEN 'INVALID'            ELSE 'VALID'        END AS EMAIL_STATUS    FROM LIG_PRD_MRCS_OH_OUTREACH_SH_DB.MRCS_OH_OUTREACH.TBL_CONTACT_EMAIL EE    INNER JOIN LIG_PRD_MRCS_OH_OUTREACH_SH_DB.MRCS_OH_OUTREACH.TBL_DEMOGRAPHIC ED        ON EE.ENTITY_ID = ED.ENTITY_ID    INNER JOIN FWRB_PRD_WMIDR_DB.BI_ANALYSIS.DIM_MEMBER DM        ON ED.MBI = DM.MEMBER_MBI    INNER JOIN FWRB_PRD_WMIDR_DB.BI_ANALYSIS.MEMBER_REPORT_MONTH MRM        ON DM.MEMBER_ID = MRM.MEMBER_ID    WHERE MRM.REPORT_MONTH = (        SELECT MAX(REPORT_MONTH)        FROM FWRB_PRD_WMIDR_DB.BI_ANALYSIS.MEMBER_REPORT_MONTH    )    QUALIFY ROW_NUMBER() OVER (        PARTITION BY ED.MBI        ORDER BY EE.UPDATEDATE DESC    ) = 1)SELECT    COALESCE(E.MBI, V.MBI) AS MBI,    E.EMAIL_STATUS AS EXPECTED_STATUS,    V.EMAIL_STATUS AS VIEW_STATUS,    CASE        WHEN E.MBI IS NULL THEN 'ONLY_IN_VIEW'        WHEN V.MBI IS NULL THEN 'ONLY_IN_EXPECTED'        WHEN E.EMAIL_STATUS <> V.EMAIL_STATUS THEN 'STATUS_MISMATCH'        ELSE 'MATCH'    END AS COMPARISON_RESULTFROM EXPECTED EFULL OUTER JOIN ASQN_PRD_MIGRATION_DB.DBO.VW_WM_UHC_MBR_EMAIL V    ON E.MBI = V.MBIWHERE E.MBI IS NULL   OR V.MBI IS NULL   OR E.EMAIL_STATUS <> V.EMAIL_STATUS;
