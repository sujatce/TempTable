 CREATE OR REPLACE PROCEDURE ASQN_PRD_ORCHESTRATION_DB.DBO.SP_LOAD_WM_UHC_MBR_OKTO_EMAIL()
RETURNS VARCHAR
LANGUAGE SQL
EXECUTE AS CALLER
AS
$$
DECLARE
    V_ROWS_INSERTED NUMBER := 0;
    V_MSG VARCHAR(255);
BEGIN
    BEGIN TRANSACTION;

    -- Log start
    LET V_MSG = 'Procedure SP_LOAD_WM_UHC_MBR_OKTO_EMAIL started.';
    CALL SYSTEM$LOG_INFO(V_MSG);

    -- Truncate the target table
    TRUNCATE TABLE ASQN_PRD_MIGRATION_DB.DBO.WM_UHC_MBR_OKTO_EMAIL;

    -- Log truncation
    LET V_MSG = 'Target table truncated.';
    CALL SYSTEM$LOG_INFO(V_MSG);

    -- Insert new data
    INSERT INTO ASQN_PRD_MIGRATION_DB.DBO.WM_UHC_MBR_OKTO_EMAIL
    (
        REPORT_MONTH,
        ENTITY_ID,
        MBI,
        MEMBER_ID,
        GMPI_ID,
        MEMBER_LAST_NAME,
        MEMBER_FIRST_NAME,
        MEMBER_EMAIL,
        EMAIL_UPDATE_DATE,
        REFRESH_DATE
    )
    SELECT DISTINCT 
        MRM.REPORT_MONTH,
        EE.ENTITY_ID,
        DM.MEMBER_MBI AS MBI,
        DM.MEMBER_ID,
        DM.GMPI_ID,
        MRM.MEMBER_LAST_NAME,
        MRM.MEMBER_FIRST_NAME,
        EE.EMAILADDRESS AS MEMBER_EMAIL,
        EE.AUDITDATE_EMAIL AS EMAIL_UPDATE_DATE,
        CURRENT_DATE() AS REFRESH_DATE
    FROM LIG_PRD_MRCS_OH_OUTREACH_SH_DB.MRCS_OH_OUTREACH.TBL_CONTACT_EMAIL EE
    INNER JOIN LIG_PRD_MRCS_OH_OUTREACH_SH_DB.MRCS_OH_OUTREACH.TBL_DEMOGRAPHIC ED
        ON EE.ENTITY_ID = ED.ENTITY_ID
    INNER JOIN FWRB_PRD_WMIDR_DB.BI_ANALYSIS.DIM_MEMBER DM
        ON ED.MBI = DM.MEMBER_MBI
    INNER JOIN FWRB_PRD_WMIDR_DB.BI_ANALYSIS.MEMBER_REPORT_MONTH MRM
        ON DM.MEMBER_ID = MRM.MEMBER_ID
    WHERE UPPER(EE.EMAIL_INVALID_IND) != 'INVALID'
      AND MRM.REPORT_MONTH = (
          SELECT MAX(REPORT_MONTH) 
          FROM FWRB_PRD_WMIDR_DB.BI_ANALYSIS.MEMBER_REPORT_MONTH
      )
      AND EE.ENTITY_ID NOT IN (
          SELECT DISTINCT ENTITY_ID 
          FROM LIG_PRD_MRCS_OH_OUTREACH_SH_DB.MRCS_OH_OUTREACH.TBL_CONSENT_DNC
          WHERE UPPER(PREF_CODE) = 'DO_NOT_EMAIL' 
            AND UPPER(SELECTED) = 'Y'
      )
    QUALIFY ROW_NUMBER() OVER (
        PARTITION BY ED.MBI 
        ORDER BY EE.AUDITDATE_EMAIL DESC
    ) = 1;

    -- Capture inserted row count
    LET V_ROWS_INSERTED = SQLROWCOUNT;

    -- Log insertion
    LET V_MSG = 'Insert completed. Rows inserted: ' || V_ROWS_INSERTED;
    CALL SYSTEM$LOG_INFO(V_MSG);

    -- Commit the transaction
    COMMIT;

    -- Return success message
    RETURN 'SP_LOAD_WM_UHC_MBR_OKTO_EMAIL completed successfully. Rows inserted: ' || V_ROWS_INSERTED;

EXCEPTION
    WHEN OTHER THEN
        -- Rollback on error
        ROLLBACK;

        -- Log the error
        LET V_MSG = 'Error in SP_LOAD_WM_UHC_MBR_OKTO_EMAIL: ' || SQLERRM;
        CALL SYSTEM$LOG_ERROR(V_MSG);

        -- Return error message
        RETURN V_MSG;
END;
$$;
