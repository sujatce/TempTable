CREATE OR REPLACE PROCEDURE ASQN_PRD_MIGRATION_DB.DBO.SP_LOAD_WM_UHC_MBR_OKTO_EMAIL()
RETURNS VARCHAR
LANGUAGE SQL
EXECUTE AS CALLER
AS '
DECLARE
    ERRORMESSAGE VARCHAR;
BEGIN

--STEP 1: Check if data exists and truncate
IF(EXISTS (SELECT 1 FROM ASQN_PRD_MIGRATION_DB.DBO.WM_UHC_MBR_OKTO_EMAIL)) THEN
    TRUNCATE TABLE ASQN_PRD_MIGRATION_DB.DBO.WM_UHC_MBR_OKTO_EMAIL;
END IF;

--STEP 2: Insert Data
INSERT INTO ASQN_PRD_MIGRATION_DB.DBO.WM_UHC_MBR_OKTO_EMAIL
(
    REPORT_MONTH,
    ENTITY_ID,
    MBI,
    MEMBER_ID,
    GMPI_ID,
    MEMBER_LAST_NAME,
    MEMBER_FIRST_NAME,
    MEMBER_EMAIL,
    EMAIL_UPDATE_DATE,
    REFRESH_DATE
)
SELECT
    REPORT_MONTH,
    ENTITY_ID,
    MBI,
    MEMBER_ID,
    GMPI_ID,
    MEMBER_LAST_NAME,
    MEMBER_FIRST_NAME,
    MEMBER_EMAIL,
    EMAIL_UPDATE_DATE,
    CURRENT_DATE()
FROM ASQN_PRD_ORCHESTRATION_DB.REPORT.VW_WM_UHC_MBR_OKTO_EMAIL_RPT;

RETURN ''Load completed successfully'';

EXCEPTION
    WHEN OTHER THEN
        ERRORMESSAGE := SQLERRM;
        ROLLBACK;
        SELECT RAISERROR_UDF(''Error : %s'', 16, 1, ARRAY_CONSTRUCT(:ERRORMESSAGE));
END';
