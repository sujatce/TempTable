# Normalize date columns without breaking Snowflake max date 9999-12-31
from datetime import date, datetime

def normalize_snowflake_date(value):
    if value is None or pd.isna(value):
        return None

    if isinstance(value, datetime):
        return value.date()

    if isinstance(value, date):
        return value

    value = str(value).strip()

    if value == "":
        return None

    # Important: handle Snowflake far-future date safely
    if value[:10] == "9999-12-31":
        return date(9999, 12, 31)

    if value[:10] == "1900-01-01":
        return date(1900, 1, 1)

    return datetime.strptime(value[:10], "%Y-%m-%d").date()


for date_col in ["MIN_DISPLAY_DATE", "MAX_DISPLAY_DATE"]:
