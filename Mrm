WITH MRM_LATEST_ACTIVE AS
(
    SELECT
        MEMBER_ID,
        MBR_ELIG_INSURANCE_COMPANY_ID,
        GMPI_ID,
        REPORT_YEAR,
        REPORT_MONTH,
        ACTIVE_FLAG,
        ROW_NUMBER() OVER
        (
            PARTITION BY MBR_ELIG_INSURANCE_COMPANY_ID
            ORDER BY REPORT_MONTH DESC
        ) AS RN
    FROM BI_ANALYSIS.dbo.MEMBER_REPORT_MONTH
    WHERE REPORT_YEAR = 2025
      AND ACTIVE_FLAG = 1
      AND MBR_ELIG_INSURANCE_COMPANY_ID IS NOT NULL
)

SELECT
    MEMBER_ID,
    MBR_ELIG_INSURANCE_COMPANY_ID,
    GMPI_ID,
    REPORT_YEAR,
    REPORT_MONTH,
    ACTIVE_FLAG
FROM MRM_LATEST_ACTIVE
WHERE RN = 1;
