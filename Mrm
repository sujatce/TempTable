select distinct [dm].[GMPI_ID],
	[dm].[MEMBER_MBI] 
from 
	(
	select [BI_Analysis].[dbo].[DIM_MEMBER].[GMPI_ID],
		[BI_Analysis].[dbo].[DIM_MEMBER].[MEMBER_MBI],
		Row_Number() 
	over 
		(
		partition by [gmpi_id] 
		order by [dw_update_date] Desc, [dw_insert_date] Desc
		) as [rn] 
	from [BI_Analysis].[dbo].[DIM_MEMBER] 
	where [BI_Analysis].[dbo].[DIM_MEMBER].[MEMBER_MBI] is not NULL 
		and [BI_Analysis].[dbo].[DIM_MEMBER].[ACTIVE_FLAG] = 1
	) [dm] 
where [dm].[rn] = 1
