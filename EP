# === PRODUCTION Config ===
API_URL = "https://gateway.optum.com/api/cel/epmp/preferences/v2/search"
INPUT_FILE = "ERRORMBI_20260425.txt"
OUTPUT_DIR = "output_chunks_errors"
CHUNK_SIZE = 100000
MAX_CONCURRENT_REQUESTS = 7
RETRY_LIMIT = 3
OAUTH_TOKEN_URL = "https://gateway.optum.com/auth/oauth2/cached/token"                                                                                            
CLIENT_ID = ""
CLIENT_SECRET = ""
CHECKPOINT_FILE = "checkpoint.json"  # Checkpoint file to track progress



# === Logging Setup ===

os.makedirs("logs", exist_ok=True)
timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
log_filename = f"logs/run_{timestamp}.log"

log_formatter = logging.Formatter("%(asctime)s [%(levelname)s] %(message)s")
