create or replace TABLE ASQN_PRD_QUALITY_DB.RAW.EPIC_KELSEY_MEDADH (
	EPIC_KELSEY_MEDADH_ID NUMBER(38,0) NOT NULL DEFAULT ASQN_PRD_QUALITY_DB.RAW.EPIC_KELSEY_MEDADH_SEQ.NEXTVAL COMMENT 'Table''s primary key',
	REPORT_MONTH DATE COMMENT 'Membership month from BI Analysis MRM stored in YYYY-MM-DD format',
	GMPI_ID NUMBER(38,0) COMMENT 'WellMed unique member identifier',
	PERSON_ID VARCHAR(50) NOT NULL COMMENT 'A unique identifier for a single person. The Person ID must be the same across all files.',
	FACT_RX_CLAIM_ID NUMBER(15,0) COMMENT 'Claim ID from the FACT_RX_CLAIM table',
	MEASURE_NAME VARCHAR(200) NOT NULL COMMENT 'Name of the measure for which the outcome was calculated',
	MEASURE_VERSION VARCHAR(20) COMMENT 'Version of the measure associated with the outcome. Typically a four-digit year indicating the certification edition of the measure.',
	MEASUREMENT_PERIOD_PATTERN VARCHAR(30) COMMENT 'Calculation period used for the measure. Describes the range of data included in the outcome.',
	PROPORTION_OF_DAYS_COVERED NUMBER(3,2) COMMENT 'The proportion of days which the person had access to the medications associated with the measure.',
	NUMERATOR_VALUE NUMBER(1,0) COMMENT 'This value indicates if the patient meets the criteria to be considered adherent for the treatment period.',
	DENOMINATOR_VALUE NUMBER(1,0) COMMENT 'This value indicates whether the patient meets the criteria to be tracked for adherence.',
	DENOMINATOR_EXCLUSION NUMBER(1,0) COMMENT 'If the patient meets the criteria to be excluded from the denominator of the measure score before determining if the numerator criteria are met.',
	DENOMINATOR_EXCEPTION NUMBER(1,0) COMMENT 'If the patient meets the criteria to be removed from the denominator of the measure score only if the numerator criteria are not met.',
	IS_IMPACTABLE BOOLEAN COMMENT 'Indicates whether the patient can be made compliant in the measurement period.',
	LAST_IMPACTABLE_DATE DATE COMMENT 'The last date to impact whether the patient meets the adherence threshold for the measure (yyyyMMdd).',
	IS_ON_FIRST_FILL BOOLEAN COMMENT 'Indicates whether the medication has been filled only once.',
	INDEX_PRESCRIPTION_START_DATE DATE COMMENT 'Date of the earliest prescription dispense in the measurement period for any medication associated with the measure (yyyyMMdd)',
	LINE_OF_BUSINESS VARCHAR(100) COMMENT 'Name of the line of business associated with the outcome',
	BENEFIT_PLAN VARCHAR(100) COMMENT 'Name of the benefit plan associated with the outcome',
	PRODUCT_LINE VARCHAR(100) COMMENT 'Name of the product line associated with the outcome',
	EMPLOYER_GROUP VARCHAR(100) COMMENT 'Name of the employer group associated with the outcome',
	PROGRAM_ID VARCHAR(100) COMMENT 'Identifier for the program associated with the outcome',
	IS_LOW_INCOME_SUBSIDY BOOLEAN COMMENT 'Indicates whether the patient is eligible for Medicare Part D Low Income Subsidy (LIS).',
	LOW_INCOME_SUBSIDY_COPAYMENT_LEVEL VARCHAR(100) COMMENT 'Patient''s copayment level for Medicare Part D Low Income Subsidy (LIS).',
	MEDICATION_NAME VARCHAR(200) COMMENT 'Name of the medication associated with the outcome.',
	MEDICATION_NDC VARCHAR(20) COMMENT 'The 11-digit National Drug Code (NDC) of the medication associated with the outcome (no dashes).',
	FIRST_FILL_DATE DATE COMMENT 'Date of the first fill for the medication (yyyyMMdd)',
	LAST_REFILL_DATE DATE COMMENT 'Date of the last refill for the medication (yyyyMMdd)',
	NEXT_REFILL_DATE DATE COMMENT 'Date of the next refill for the medication (yyyyMMdd)',
	REFILLS_REMAINING NUMBER(3,0) COMMENT 'Number of refills remaining for the medication before a refill request must be approved to obtain additional fills',
	DAYS_SUPPLY NUMBER(3,0) COMMENT 'Number of days covered by the dispensed supply of the medication',
	ELIGIBLE_FOR_EXTENDED_DAYS_SUPPLY VARCHAR(100) COMMENT 'Indicates whether the patient is eligible for a greater days supply of the medication.',
	PRESCRIBING_PROVIDER_NAME VARCHAR(200) COMMENT 'Name of the provider who prescribed the medication',
	PRESCRIBING_PROVIDER_NPI VARCHAR(20) COMMENT 'The National Provider Identifier (NPI) of the provider who prescribed the medication',
	PRESCRIBING_PROVIDER_PHONE_NUMBER VARCHAR(30) COMMENT 'Prescribing provider''s phone number. All NANP-compliant formats are accepted.',
	PHARMACY_NAME VARCHAR(200) COMMENT 'Name of the pharmacy that dispensed the medication',
	PHARMACY_NPI VARCHAR(20) COMMENT 'The National Provider Identifier (NPI) of the pharmacy that dispensed the medication',
	PHARMACY_PHONE_NUMBER VARCHAR(30) COMMENT 'Pharmacy''s phone number. All NANP-compliant formats are accepted.',
	PHARMACY_DISTRIBUTION_METHOD VARCHAR(50) COMMENT 'The method by which the patient received the medication from the pharmacy.',
	IS_PREFERRED_PHARMACY BOOLEAN COMMENT 'Indicates whether the pharmacy that dispensed the medication is a preferred pharmacy for the payer.',
	USER_STORY VARCHAR(25) COMMENT 'User story ID associated with data ingestion or update',
	INSERT_DATE TIMESTAMP_NTZ(7) NOT NULL DEFAULT CAST(CONVERT_TIMEZONE('America/Chicago', CAST(CURRENT_TIMESTAMP() AS TIMESTAMP_TZ(9))) AS TIMESTAMP_NTZ(7)) COMMENT 'Timestamp recording when the row was inserted',
	INSERT_USER VARCHAR(75) NOT NULL DEFAULT CURRENT_USER() COMMENT 'USER ID that first inserted data in the row',
	UPDATE_DATE TIMESTAMP_NTZ(7) NOT NULL DEFAULT CAST(CONVERT_TIMEZONE('America/Chicago', CAST(CURRENT_TIMESTAMP() AS TIMESTAMP_TZ(9))) AS TIMESTAMP_NTZ(7)) COMMENT 'Timestamp recording when the row was last updated',
	UPDATE_USER VARCHAR(75) NOT NULL DEFAULT CURRENT_USER() COMMENT 'USER ID that last updated data in the row',
	LOAD_DATE DATE NOT NULL DEFAULT CAST(CONVERT_TIMEZONE('America/Chicago', CAST(CURRENT_TIMESTAMP() AS TIMESTAMP_TZ(9))) AS DATE) COMMENT 'Date recording when the row was inserted',
	constraint PK_EK_MEDADH_PRIMARYKEY primary key (EPIC_KELSEY_MEDADH_ID)
)COMMENT='This table contains outcomes for medication adherence measures. Each row represents the outcome of a medication adherence measure in the measurement period for a patient.'
;
