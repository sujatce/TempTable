✅ Step 2B: Return ALL procedure codes in ONE column (comma-separated)

This keeps it one row (best for a segment file).

DECLARE @GMPI_ID BIGINT = 123456789;

SELECT
    ev.GMPI_ID,
    CAST(ev.ER_DATE AS date) AS LAST_ER_DATE,
    ev.CLAIM_ID_ER,
    ev.HOSPITAL_PROVIDER,
    ev.ER_STATUS,
    ev.ER_CATEGORY,
    STRING_AGG(CONCAT(fcp.CODE, ' - ', COALESCE(fcp.CODE_NAME,'')), ' | ') 
        WITHIN GROUP (ORDER BY fcp.SERVICE_FROM_DATE, fcp.SERVICE_LINE) AS ALL_PROCEDURE_CODES
FROM (
    SELECT TOP (1) *
    FROM BI_ANALYSIS.dbo.FACT_ER_VISITS
    WHERE ER_STATUS = 'TRUE ER'
      AND GMPI_ID = @GMPI_ID
      AND ER_DATE >= DATEADD(day, -90, CAST(GETDATE() AS date))
    ORDER BY ER_DATE DESC
) ev
JOIN BI_ANALYSIS.dbo.FACT_CLAIM_PROCEDURE fcp
    ON fcp.CLAIM_ID = ev.CLAIM_ID_ER
GROUP BY
    ev.GMPI_ID,
    CAST(ev.ER_DATE AS date),
    ev.CLAIM_ID_ER,
    ev.HOSPITAL_PROVIDER,
    ev.ER_STATUS,
    ev.ER_CATEGORY;
