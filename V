-- General query: all records except the bad Linda duplicate phone
SELECT
    GMPI_ID,
    MEMBER_LAST_NAME,
    MEMBER_FIRST_NAME,
    MEMBER_PHONE,
    MBI
FROM ASQN_PRD_ORCHESTRATION_DB.REPORT.VW_WM_UHC_MBR_PHONE_RPT
WHERE MEMBER_PHONE <> '7023042111'

UNION

-- Correct record: pick Juan for that phone
SELECT
    GMPI_ID,
    MEMBER_LAST_NAME,
    MEMBER_FIRST_NAME,
    MEMBER_PHONE,
    MBI
FROM ASQN_PRD_ORCHESTRATION_DB.REPORT.VW_WM_UHC_MBR_PHONE_RPT
WHERE MEMBER_PHONE = '7023042111'
  AND UPPER(MEMBER_FIRST_NAME) = 'JUAN';
