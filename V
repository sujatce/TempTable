create or replace TABLE ASQN_PRD_ORCHESTRATION_DB.DBO.WM_UHC_MBR_EMAIL (
	REPORT_MONTH DATE NOT NULL COMMENT 'Month of the member empanelment in BI Analysis MRM stored in YYYY-MM-DD format',
	ENTITY_ID VARCHAR(100) NOT NULL COMMENT 'A unique number used by the enterprise to identify an individual person',
	MBI VARCHAR(20) NOT NULL COMMENT 'Member Beneficiary Identifier issued by CMS to identify Medicare beneficiaries',
	MEMBER_ID NUMBER(15,0) COMMENT 'WellMed BI Analysis DIM_MEMBER unique MEMBER_ID',
	GMPI_ID NUMBER(38,0) COMMENT 'WellMed unique member identifier',
	MEMBER_LAST_NAME VARCHAR(60) COMMENT 'Last name of the member enrolled in the health plan',
	MEMBER_FIRST_NAME VARCHAR(50) COMMENT 'First name of the member enrolled in the health plan',
	MEMBER_EMAIL VARCHAR(250) NOT NULL COMMENT 'Member Email Address',
	EMAIL_STATUS VARCHAR(20) COMMENT 'Member Email Status shows validity of the member email address(VALID or INVALID)',
	EMAIL_UPDATE_DATE DATE NOT NULL COMMENT 'Date recording when the email address was last updated',
	REFRESH_DATE DATE NOT NULL COMMENT 'System date when the table was last fully refreshed stored in YYYY-MM-DD format'
)COMMENT='The WellMed Central Quality Performance Analytics team manages integration with UHC data sources for the purpose of sourcing member email address and email preferences.  This data is used for campaign orchestration, reporting and suppression purposes, to reduce member abrasion, and to follow enterprise email outreach compliance requirements. This table is limited to South Region WellMed membership and includes members with valid or invalid email addresses, per UHC. It is not inclusive of other Email Unsubscribe or Bounceback data sourced from Optum Health outreach initiatives.'
;

