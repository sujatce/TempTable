SELECT DISTINCT
    PROCEDURE_CODE,
    PROCEDURE_NAME,
    PROCEDURE_DESCRIPTION
FROM fwrb_prd_wmidr_db.casenet.procedurecode
WHERE PROCEDURE_CODE LIKE 'G%'
  AND (
       SEARCH(PROCEDURE_DESCRIPTION, 'LAB')
    OR SEARCH(PROCEDURE_NAME, 'LAB')
    OR SEARCH(PROCEDURE_DESCRIPTION, 'TEST')
    OR SEARCH(PROCEDURE_NAME, 'TEST')
    OR SEARCH(PROCEDURE_DESCRIPTION, 'LABORATORY')
    OR SEARCH(PROCEDURE_NAME, 'LABORATORY')
  )
ORDER BY PROCEDURE_CODE;



  SELECT DISTINCT PROCEDURE_CODE,PROCEDURE_NAME,PROCEDURE_DESCRIPTION
  FROM fwrb_prd_wmidr_db.casenet.procedurecode
WHERE SEARCH(PROCEDURE_DESCRIPTION, 'LAB') 
  OR SEARCH(PROCEDURE_NAME, 'LAB')
UNION
SELECT DISTINCT PROCEDURE_CODE,PROCEDURE_NAME,PROCEDURE_DESCRIPTION
  FROM fwrb_prd_wmidr_db.casenet.procedurecode
WHERE SEARCH(PROCEDURE_DESCRIPTION, 'TEST') 
  OR SEARCH(PROCEDURE_NAME, 'TEST')
  union
  SELECT DISTINCT PROCEDURE_CODE,PROCEDURE_NAME,PROCEDURE_DESCRIPTION
  FROM fwrb_prd_wmidr_db.casenet.procedurecode
WHERE SEARCH(PROCEDURE_DESCRIPTION, 'LABORATORY') 
  OR SEARCH(PROCEDURE_NAME, 'LABORATORY')



