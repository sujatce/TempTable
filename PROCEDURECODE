

SELECT DISTINCT PROCEDURE_CODE,PROCEDURE_NAME,PROCEDURE_DESCRIPTION
  FROM fwrb_prd_wmidr_db.casenet.procedurecode
WHERE PROCEDURE_DESCRIPTION LIKE '%lab%' or
procedure_name like '%LAB%' or
PROCEDURE_DESCRIPTION LIKE '%test%' or
procedure_name like '%TEST%' 
ORDER BY PROCEDURE_CODE
-

SELECT DISTINCT PROCEDURE_CODE,PROCEDURE_NAME,PROCEDURE_DESCRIPTION
  FROM fwrb_prd_wmidr_db.casenet.procedurecode
WHERE SEARCH(PROCEDURE_DESCRIPTION, 'LAB') 
  OR SEARCH(PROCEDURE_NAME, 'LAB')
UNION
SELECT DISTINCT PROCEDURE_CODE,PROCEDURE_NAME,PROCEDURE_DESCRIPTION
  FROM fwrb_prd_wmidr_db.casenet.procedurecode
WHERE SEARCH(PROCEDURE_DESCRIPTION, 'TEST') 
  OR SEARCH(PROCEDURE_NAME, 'TEST')
