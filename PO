SELECT
  code,
  code_name,
  COUNT(*) AS cnt
FROM FWRB_PRD_WMIDR_DB.BI_ANALYSIS.FACT_CLAIM_PROCEDURE
WHERE service_from_date >= DATEADD(day, -60, CURRENT_DATE)
  AND code_name IS NOT NULL
  AND (
        UPPER(code_name) LIKE '%EMERGENCY DEPARTMENT VISIT%'
       OR UPPER(code_name) LIKE '%EMERGENCY DEPT%'
  --   OR UPPER(code_name) LIKE '%ED%'
   --  OR UPPER(code_name) LIKE '%DEPARTMENT%'
  )
GROUP BY code, code_name
ORDER BY cnt DESC;


