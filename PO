create or replace secure view ASQN_DEV_ORCHESTRATION_DB.ACCESS.VW_WM_PILLS_ON_HAND(
	PILLS_ON_HAND_ID COMMENT 'Auto-generated Unique ID',
	GMPI_ID COMMENT 'Unique Member identifier internal to Wellmed',
	MBI COMMENT 'Medicare Beneficiary Identifier',
	PATIENT_MISMATCH COMMENT 'Flag to indicate if the member has a matching record in BI Analysis',
	ENTERPRISE_INDV_ID COMMENT 'An identification number assigned by UHC help identify members across UHC systems',
	HEALTH_PLAN_MEMBERSHIP_ID,
	MAC_SUPPLY_IN_HAND_12M COMMENT 'MAC meds supply in hand looking back at a time window of past 12 months',
	MAD_SUPPLY_IN_HAND_12M COMMENT 'MAD meds supply in hand looking back at a time window of past 12 months',
	MAH_SUPPLY_IN_HAND_12M COMMENT 'MAH meds supply in hand looking back at a time window of past 12 months',
	CONTRACT_NUMBER COMMENT 'Contract ID associated with the member enrolled health plan',
	PBP COMMENT 'Contract Plan Benefit package associated with the member enrolled health plan',
	SEGMENT COMMENT 'Contract Segment associated with the member enrolled health plan',
	HPBP COMMENT 'Contract Number and PBP associated with the member enrolled health plan',
	CONTRACT_MARKET COMMENT 'Contract Market associated with the member enrolled health plan',
	MEMBER_STATE COMMENT 'State associated with the member',
	MEMBER_MARKET COMMENT 'Market associated with the member',
	PAYER_MARKET,
	OC_FLAG COMMENT 'OptumCare flag, used for identifying OptumCare members',
	OC_SEGMENT,
	EMR_FLAG COMMENT 'Flag to determine a Home and Community member',
	HC_OC_COMANAGED_FLAG,
	MAC_PRED_OUTPUT COMMENT 'Likelihood that member is NOT adherent in MAC (large values means more likely to be non-adherent)',
	MAC_PRED_LABEL COMMENT 'Label for predicted probabiliy of non-adherence for MAC (1 is predicted NOT adherent)',
	MAD_PRED_OUTPUT COMMENT 'Likelihood that member is NOT adherent in MAD (large values means more likely to be non-adherent)',
	MAD_PRED_LABEL COMMENT 'Label for predicted probabiliy of non-adherence for MAH (1 is predicted NOT adherent)',
	MAH_PRED_OUTPUT COMMENT 'Likelihood that member is NOT adherent in MAH (large values means more likely to be non-adherent)',
	MAH_PRED_LABEL COMMENT 'Label for predicted probabiliy of non-adherence for MAH (1 is predicted NOT adherent)',
	MAC_CURRENT_SUPPLY_DAYS,
	MAC_MIN_SUPPLY_DAYS,
	MAC_MAX_SUPPLY_DAYS,
	MAC_FILLS COMMENT 'Number of MAC fills during calendar year',
	MAC_CURRENT_PDC,
	MAC_MIN_PDC,
	MAC_MAX_PDC,
	MAC_MIN_FILLS_NEEDED,
	MAC_ALLOWABLE_DAYS_REMAINING,
	MAC_DEFINITE_ADHERENT,
	MAC_DEFINITE_NON_ADHERENT,
	MAC_CLAIMS_TOTAL_COUNT_12M COMMENT 'Total number of MAC Rx claims looking back at a time window of past 12 months',
	MAC_DAYS_SINCE_LAST_FILL COMMENT 'Days since the last fill of MAC medication',
	MAC_NEW_TO_THERAPY_3M COMMENT 'Indicator if member is new to therapy for MAC (1st medication in the past 3 months, no history of claims in the past 2years, contract independent)',
	MAC_NTT_RESTART_3M COMMENT 'Indicator if member restarted therapy for MAC (1st medication in the past 3 months after break in medication of 180 days or higher in the past 2years, contract independent)',
	MAC_NTT_CURRENT_YEAR COMMENT 'Indicator if member was flagged new to therapy for MAC at any point in the current year',
	MAD_CURRENT_SUPPLY_DAYS,
	MAD_MIN_SUPPLY_DAYS,
	MAD_MAX_SUPPLY_DAYS,
	MAD_FILLS COMMENT 'Number of MAD fills during calendar year',
	MAD_CURRENT_PDC,
	MAD_MIN_PDC,
	MAD_MAX_PDC,
	MAD_MIN_FILLS_NEEDED,
	MAD_ALLOWABLE_DAYS_REMAINING,
	MAD_DEFINITE_ADHERENT,
	MAD_DEFINITE_NON_ADHERENT,
	MAD_CLAIMS_TOTAL_COUNT_12M COMMENT 'Total number of MAD Rx claims looking back at a time window of past 12 months',
	MAD_DAYS_SINCE_LAST_FILL COMMENT 'Days since the last fill of MAD medication',
	MAD_NEW_TO_THERAPY_3M COMMENT 'Indicator if member is new to therapy for MAD (1st medication in the past 3 months, no history of claims in the past 2years, contract independent)',
	MAD_NTT_RESTART_3M COMMENT 'Indicator if member restarted therapy for MAD (1st medication in the past 3 months after break in medication of 180 days or higher in the past 2years, contract independent)',
	MAD_NTT_CURRENT_YEAR COMMENT 'Indicator if member was flagged new to therapy for MAD at any point in the current year',
	MAH_CURRENT_SUPPLY_DAYS,
	MAH_MIN_SUPPLY_DAYS,
	MAH_MAX_SUPPLY_DAYS,
	MAH_FILLS COMMENT 'Number of MAH fills during calendar year',
	MAH_CURRENT_PDC,
	MAH_MIN_PDC,
	MAH_MAX_PDC,
	MAH_MIN_FILLS_NEEDED,
	MAH_ALLOWABLE_DAYS_REMAINING,
	MAH_DEFINITE_ADHERENT,
	MAH_DEFINITE_NON_ADHERENT,
	MAH_CLAIMS_TOTAL_COUNT_12M COMMENT 'Total number of MAH Rx claims looking back at a time window of past 12 months',
	MAH_DAYS_SINCE_LAST_FILL COMMENT 'Days since the last fill of MAH medication',
	MAH_NEW_TO_THERAPY_3M COMMENT 'Indicator if member is new to therapy for MAH (1st medication in the past 3 months, no history of claims in the past 2years, contract independent)',
	MAH_NTT_RESTART_3M COMMENT 'Indicator if member restarted therapy for MAH (1st medication in the past 3 months after break in medication of 180 days or higher in the past 2years, contract independent)',
	MAH_NTT_CURRENT_YEAR COMMENT 'Indicator if member was flagged new to therapy for MAH at any point in the current year',
	RPT_KEY COMMENT 'Date of model prediction outputs.',
	ENCRYPT COMMENT 'Flag to Identify if member is Offshore/Onshore',
	COMBINED_PRED_PROB,
	REFRESH_DATE,
	PREP_DATETIME,
	PROCESS_LOG_ID,
	LOAD_DATETIME,
	RECORD_ID,
	UPDATE_DATE,
	MAC_PRED_PDC_OUTPUT,
	MAC_CAL_PRED_OUTPUT,
	MAD_PRED_PDC_OUTPUT,
	MAD_CAL_PRED_OUTPUT,
	MAH_PRED_PDC_OUTPUT,
	MAH_CAL_PRED_OUTPUT
) as 
SELECT
PILLS_ON_HAND_ID,
GMPI_ID,
MBI,
PATIENT_MISMATCH,
ENTERPRISE_INDV_ID,
HEALTH_PLAN_MEMBERSHIP_ID,
MAC_SUPPLY_IN_HAND_12M,
MAD_SUPPLY_IN_HAND_12M,
MAH_SUPPLY_IN_HAND_12M,
CONTRACT_NUMBER,
PBP,
SEGMENT,
HPBP,
CONTRACT_MARKET,
MEMBER_STATE,
MEMBER_MARKET,
PAYER_MARKET,
OC_FLAG,
OC_SEGMENT,
EMR_FLAG,
HC_OC_COMANAGED_FLAG,
MAC_PRED_OUTPUT,
MAC_PRED_LABEL,
MAD_PRED_OUTPUT,
MAD_PRED_LABEL,
MAH_PRED_OUTPUT,
MAH_PRED_LABEL,
MAC_CURRENT_SUPPLY_DAYS,
MAC_MIN_SUPPLY_DAYS,
MAC_MAX_SUPPLY_DAYS,
MAC_FILLS,
MAC_CURRENT_PDC,
MAC_MIN_PDC,
MAC_MAX_PDC,
MAC_MIN_FILLS_NEEDED,
MAC_ALLOWABLE_DAYS_REMAINING,
MAC_DEFINITE_ADHERENT,
MAC_DEFINITE_NON_ADHERENT,
MAC_CLAIMS_TOTAL_COUNT_12M,
MAC_DAYS_SINCE_LAST_FILL,
MAC_NEW_TO_THERAPY_3M,
MAC_NTT_RESTART_3M,
MAC_NTT_CURRENT_YEAR,
MAD_CURRENT_SUPPLY_DAYS,
MAD_MIN_SUPPLY_DAYS,
MAD_MAX_SUPPLY_DAYS,
MAD_FILLS,
MAD_CURRENT_PDC,
MAD_MIN_PDC,
MAD_MAX_PDC,
MAD_MIN_FILLS_NEEDED,
MAD_ALLOWABLE_DAYS_REMAINING,
MAD_DEFINITE_ADHERENT,
MAD_DEFINITE_NON_ADHERENT,
MAD_CLAIMS_TOTAL_COUNT_12M,
MAD_DAYS_SINCE_LAST_FILL,
MAD_NEW_TO_THERAPY_3M,
MAD_NTT_RESTART_3M,
MAD_NTT_CURRENT_YEAR,
MAH_CURRENT_SUPPLY_DAYS,
MAH_MIN_SUPPLY_DAYS,
MAH_MAX_SUPPLY_DAYS,
MAH_FILLS,
MAH_CURRENT_PDC,
MAH_MIN_PDC,
MAH_MAX_PDC,
MAH_MIN_FILLS_NEEDED,
MAH_ALLOWABLE_DAYS_REMAINING,
MAH_DEFINITE_ADHERENT,
MAH_DEFINITE_NON_ADHERENT,
MAH_CLAIMS_TOTAL_COUNT_12M,
MAH_DAYS_SINCE_LAST_FILL,
MAH_NEW_TO_THERAPY_3M,
MAH_NTT_RESTART_3M,
MAH_NTT_CURRENT_YEAR,
RPT_KEY,
ENCRYPT,
COMBINED_PRED_PROB,
REFRESH_DATE,
PREP_DATETIME,
PROCESS_LOG_ID,
LOAD_DATETIME,
RECORD_ID,
UPDATE_DATE,
MAC_PRED_PDC_OUTPUT,
MAC_CAL_PRED_OUTPUT,
MAD_PRED_PDC_OUTPUT,
MAD_CAL_PRED_OUTPUT,
MAH_PRED_PDC_OUTPUT,
MAH_CAL_PRED_OUTPUT 
FROM ASQN_DEV_ORCHESTRATION_DB.DBO.PILLS_ON_HAND
WHERE UPDATE_DATE <= (SELECT MAX_DISPLAY_DATE 
                    FROM ASQN_DEV_CFG_DB.DBO.CFG_VW_CONTROL
                    WHERE VIEW_NAME = 'VW_WM_PILLS_ON_HAND')
AND UPDATE_DATE >= (SELECT MIN_DISPLAY_DATE 
                    FROM ASQN_DEV_CFG_DB.DBO.CFG_VW_CONTROL
                    WHERE VIEW_NAME = 'VW_WM_PILLS_ON_HAND');
