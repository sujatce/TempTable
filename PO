SELECT
    p.PROVIDER_ID,
    p.PROVIDER_FULL_NAME,
    p.NPI_ID,
    s.PROVIDER_SPECIALTY_CODE,
    l.PROVIDER_SPECIALTY_DESC,
    CASE
        WHEN UPPER(TRIM(l.PROVIDER_SPECIALTY_DESC)) IN (
            'FAMILY PRACTICE',
            'PHYSICIAN/FAMILY PRACTICE',
            'FAMILY MEDICINE',
            'INTERNAL MEDICINE',
            'PHYSICIAN/INTERNAL MEDICINE',
            'GENERAL PRACTICE',
            'PHYSICIAN/GENERAL PRACTICE',
            'PEDIATRICS',
            'PEDIATRIC MEDICINE',
            'PHYSICIAN/PEDIATRIC MEDICINE',
            'GERIATRIC MEDICINE',
            'PCP',
            'PCP OTHER'
        ) THEN 'PCP'
        WHEN UPPER(TRIM(l.PROVIDER_SPECIALTY_DESC)) IN (
            'UNKNOWN',
            'UNK',
            'UNKNOWN PHYSICIAN SPECIALTY',
            'UNKNOWN PROVIDER',
            'MEDICAL DOCTOR',
            'PHYSICIAN',
            'PHYSICIAN/UNDEFINED PHYSICIAN TYPE',
            'PHYSICIAN/UNDEFINED PHYSICIAN TYPE[6]',
            'PHYSICIAN/UNDEFINED PHYSICAN TYPE'
        ) THEN 'UNKNOWN'
        ELSE 'SPECIALIST_OR_OTHER'
    END AS PROVIDER_CLASS
FROM FWRB_PRD_WMIDR_DB.BI_ANALYSIS.DIM_PROVIDER p
JOIN FWRB_PRD_WMIDR_DB.BI_ANALYSIS.DIM_PROVIDER_SPECIALTY s
    ON p.PROVIDER_ID = s.PROVIDER_ID
LEFT JOIN FWRB_PRD_WMIDR_DB.BI_ANALYSIS.DIM_PROVIDER_SPECIALTY_LKP l
    ON s.PROVIDER_SPECIALTY_CODE = l.PROVIDER_SPECIALTY_CODE
WHERE p.ACTIVE_FLAG = 1
  AND s.ACTIVE_FLAG = 1;
