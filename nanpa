SELECT TOP (5000)
    dm.GMPI_ID,
    dm.MEMBER_MBI,
    dm.MEMBER_FIRST_NAME,
    dm.MEMBER_LAST_NAME,
    dm.MEMBER_DATE_OF_BIRTH,
    CAST(ev.ER_DATE AS date) AS ER_DATE,
    ev.HOSPITAL_PROVIDER,
    ev.ER_STATUS,
    ev.ER_CATEGORY,
    ev.CLAIM_ID_ER
FROM BI_ANALYSIS.dbo.FACT_ER_VISITS ev
LEFT JOIN BI_ANALYSIS.dbo.dim_member dm
    ON dm.GMPI_ID = ev.GMPI_ID
WHERE ev.ER_STATUS = 'TRUE ER'
  AND ev.ER_DATE >= DATEADD(day, -10, CAST(GETDATE() AS date))
ORDER BY ev.ER_DATE DESC;
