import streamlit as st
# Import get_active_session if running in Streamlit in Snowflake
from snowflake.snowpark.context import get_active_session 
# from snowflake.snowpark import Session # Use this if running locally and managing connections manually

# Function to get the active Snowpark session
# If running in Snowflake, st.connection("snowflake") is also a valid way to get the session
def get_session():
    return get_active_session()

st.set_page_config(layout="wide")

session = get_session()
TABLE_NAME = "CFG_VW_CONTROL" # Replace with your table details
COL_1="PROGRAM_NAME" # Replace with column name
COL_2="VIEW_NAME" # Replace with column name

st.title(":orange[Cfg View Control]")
st.subheader(":blue[Search for Program or View]")

# --- 1. Search for records ---
with st.form("search_form"):
        search_value = st.text_input("**Enter Value:**")
        search_button = st.form_submit_button(label="Search")
   
    
if search_button and search_value:
    try:
        # Query the table based on the search criteria
        # Use prepared statements (?) for security against SQL injection

        query = f"SELECT CFG_VW_CONTROL_ID,PROGRAM_NAME,VIEW_NAME,MIN_DISPLAY_DATE,MAX_DISPLAY_DATE,COMMENTS,USER_STORY FROM {TABLE_NAME} WHERE {COL_1} ILIKE ? OR {COL_2} ILIKE ?"

         # Add wildcards for partial matching
        search_pattern = f"%{search_value}%"

        df = session.sql(query, params=[search_pattern, search_pattern]).to_pandas()
      
        if not df.empty:
            st.success(f"Found {len(df)} records.")
            # Store the search results in session state for later updates
            st.session_state["search_results"] = df
        else:
            st.warning("No record found.")
            st.session_state["search_results"] = None
    except Exception as e:
        st.error(f"Error during search: {e}")
        

# --- 2. Display and edit records ---
if "search_results" in st.session_state and st.session_state["search_results"] is not None:
    st.subheader(":blue[Edit Records]")
    # Use st.data_editor to allow users to make changes to the data
    edited_df = st.data_editor(st.session_state["search_results"],num_rows="fixed",hide_index=True,disabled=["CFG_VW_CONTROL_ID","PROGRAM_NAME","VIEW_NAME"])
    
    # Store the edited data in session state as well
    st.session_state["edited_data"] = edited_df

    update_button = st.button("Update")

    # --- 3. Update the Snowflake table ---
    if update_button:
        try:
            # For simplicity, this example overwrites the filtered/edited rows in the database
            # A more robust solution for large tables would involve tracking specific changes
            # using Streamlit's data editor capabilities (e.g., st.experimental_get_editor_changes)
            
            # Convert the edited pandas DataFrame back to a Snowpark DataFrame
            snowpark_df_changes = session.create_dataframe(st.session_state["edited_data"])

            # Save changes back to the original table
            # This uses the Snowpark DataFrame update method which provides a more robust way to handle updates
            target_table = session.table(TABLE_NAME)
            
            # Define how to update. The 'KEY_COLUMN' needs to be a unique identifier in your table
            # Replace 'ID' with your actual primary/unique key column name
            KEY_COLUMN = 'CFG_VW_CONTROL_ID' 
            
            # Create a dictionary for column assignments for the update
            assignments = {col: snowpark_df_changes[col] for col in snowpark_df_changes.columns if col != KEY_COLUMN}
            
            # Perform the update
            target_table.update(
                assignments=assignments,
                condition=target_table[KEY_COLUMN] == snowpark_df_changes[KEY_COLUMN],
                source=snowpark_df_changes
            )
            
            st.success("Records successfully updated in CFG_VW_CONTROL table.")
            # Clear session state to prompt a re-search and re-display
            del st.session_state["search_results"]
            del st.session_state["edited_data"]

        except Exception as e:
            st.error(f"Error applying updates: {e}")
