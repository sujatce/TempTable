/* STEP 1: Collect latest ER visit per member in last 30 days */
IF OBJECT_ID('tempdb..#er30') IS NOT NULL DROP TABLE #er30;

SELECT
    ev.GMPI_ID,
    CAST(ev.ER_DATE AS date) AS LAST_ER_DATE,
    ev.CLAIM_ID_ER,
    ev.HOSPITAL_PROVIDER,
    ev.ER_STATUS,
    ev.ER_CATEGORY
INTO #er30
FROM (
    SELECT
        ev.*,
        ROW_NUMBER() OVER (PARTITION BY ev.GMPI_ID ORDER BY ev.ER_DATE DESC) AS rn
    FROM BI_ANALYSIS.dbo.FACT_ER_VISITS ev
    WHERE ev.ER_STATUS = 'TRUE ER'
      AND ev.ER_DATE >= DATEADD(day, -30, CAST(GETDATE() AS date))
) ev
WHERE ev.rn = 1;


/* STEP 2 + 3: Final Output (aggregate procedures inline) */
SELECT
    dm.GMPI_ID,
    dm.MEMBER_MBI,
    dm.MEMBER_FIRST_NAME,
    dm.MEMBER_LAST_NAME,
    dm.MEMBER_DATE_OF_BIRTH,

    e.LAST_ER_DATE,
    e.CLAIM_ID_ER,
    e.HOSPITAL_PROVIDER,
    e.ER_STATUS,
    e.ER_CATEGORY,

    p.PROC_LINE_COUNT,
    p.ALL_PROCEDURE_CODES

FROM #er30 e
LEFT JOIN BI_ANALYSIS.dbo.dim_member dm
    ON dm.GMPI_ID = e.GMPI_ID

LEFT JOIN (
    SELECT
        fcp.CLAIM_ID,
        COUNT(*) AS PROC_LINE_COUNT,
        STRING_AGG(CAST(fcp.CODE AS VARCHAR(MAX)), ',')
            WITHIN GROUP (ORDER BY fcp.SERVICE_FROM_DATE, fcp.SERVICE_LINE) AS ALL_PROCEDURE_CODES
    FROM BI_ANALYSIS.dbo.FACT_CLAIM_PROCEDURE fcp
    JOIN #er30 e2
        ON e2.CLAIM_ID_ER = fcp.CLAIM_ID
    GROUP BY fcp.CLAIM_ID
) p
    ON p.CLAIM_ID = e.CLAIM_ID_ER

ORDER BY e.LAST_ER_DATE DESC;
