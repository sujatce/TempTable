SELECT DISTINCT
    dm.MEMBER_MBI,
    mrm.GMPI_ID,
    mrm.MEMBER_FIRST_NAME,
    mrm.MEMBER_LAST_NAME,
    mrm.CONTRACT_ID,
    mrm.CONTRACT_PBP
FROM BI_ANALYSIS.dbo.MEMBER_REPORT_MONTH mrm

LEFT JOIN BI_ANALYSIS.dbo.DIM_CLINIC dc
    ON mrm.CLINIC_ID = dc.CLINIC_ID
   AND dc.ACTIVE_FLAG = 1

LEFT JOIN BI_ANALYSIS.dbo.DIM_MEMBER dm
    ON mrm.GMPI_ID = dm.GMPI_ID
   AND mrm.MEMBER_ID = dm.MEMBER_ID
   AND dm.ACTIVE_FLAG = 1

WHERE mrm.DATA_ENTITY = 'Wellmed'
  AND (dc.CLINIC_RELATION = 'Affiliated' OR mrm.OWNED_FLAG = 0)
  AND mrm.ACTIVE_FLAG = 1
  AND mrm.IS_HOSPICE_FLAG = 0
  AND mrm.LTI_FLAG = 0
  AND mrm.ESRD_FLAG = 0
  AND dm.MEMBER_MBI IS NOT NULL
  AND mrm.REPORT_MONTH = '2026-03-01'
  AND mrm.CLINIC_GROUP_NAME NOT IN ('SWHR')
  AND mrm.MBR_ELIG_INSURANCE_COMPANY_FULL_NAME LIKE 'United%'
ORDER BY dm.MEMBER_MBI;
