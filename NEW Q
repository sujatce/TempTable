SELECT
    ev.CLAIM_ID_ER,
    COUNT(*) AS procedure_lines
FROM BI_ANALYSIS.dbo.FACT_ER_VISITS ev
JOIN BI_ANALYSIS.dbo.FACT_CLAIM_PROCEDURE fcp
    ON fcp.CLAIM_ID = ev.CLAIM_ID_ER
WHERE ev.ER_STATUS = 'TRUE ER'
GROUP BY ev.CLAIM_ID_ER
ORDER BY procedure_lines DESC;



SELECT
    GMPI_ID,
    ER_DATE,
    COUNT(*) AS rows_per_visit
FROM BI_ANALYSIS.dbo.FACT_ER_VISITS
GROUP BY GMPI_ID, ER_DATE
HAVING COUNT(*) > 1
ORDER BY rows_per_visit DESC;
