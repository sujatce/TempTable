WITH er_candidate AS (

    SELECT
        dra.GMPI_ID,
        CAST(dra.RESULT_DATE AS DATE) AS ER_VISIT_DATE,
        dra.RESULT_CODE,
        dra.CODE_TYPE,
        dra.CLAIM_SPECIALTY_VALUE

    FROM fwrb_prd_wmidr_db.bi_analysis.definition_result_active dra

    WHERE
        -- Lookback window
        dra.RESULT_DATE >= DATEADD(day, -365, CURRENT_DATE)

        -- Safer Specialty Filter (include NULLs)
        AND (
               UPPER(dra.CLAIM_SPECIALTY_VALUE) LIKE '%EMERGENCY%'
               OR dra.CLAIM_SPECIALTY_VALUE IS NULL
            )

        AND
        (
              -- CPT Emergency Department E/M
              (dra.CODE_TYPE = 'CPT'
               AND dra.RESULT_CODE IN ('99281','99282','99283','99284','99285'))

           OR -- HCPCS ED visit codes
              (dra.CODE_TYPE = 'HCPCS'
               AND dra.RESULT_CODE IN ('G0380','G0381','G0382','G0383','G0384'))

           OR -- Optional Observation codes (remove if business decides to exclude)
              (dra.CODE_TYPE = 'CPT'
               AND dra.RESULT_CODE IN ('99217','99218','99219','99220'))
        )

),

-- Deduplicate multiple claim lines on same day per member
er_visits AS (

    SELECT
        GMPI_ID,
        ER_VISIT_DATE,
        COUNT(*) AS LINE_COUNT
    FROM er_candidate
    GROUP BY GMPI_ID, ER_VISIT_DATE

),

-- Member level aggregation
member_er_summary AS (

    SELECT
        GMPI_ID,
        MAX(ER_VISIT_DATE) AS LAST_ER_VISIT_DATE,

        COUNT(CASE WHEN ER_VISIT_DATE >= DATEADD(day, -30, CURRENT_DATE) THEN 1 END)
            AS ER_VISITS_LAST_30_DAYS,

        COUNT(CASE WHEN ER_VISIT_DATE >= DATEADD(day, -90, CURRENT_DATE) THEN 1 END)
            AS ER_VISITS_LAST_90_DAYS,

        COUNT(CASE WHEN ER_VISIT_DATE >= DATEADD(day, -365, CURRENT_DATE) THEN 1 END)
            AS ER_VISITS_LAST_365_DAYS

    FROM er_visits
    GROUP BY GMPI_ID
)

SELECT *
FROM member_er_summary
ORDER BY LAST_ER_VISIT_DATE DESC;
