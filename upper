import streamlit as st

# Import get_active_session if running in Streamlit in Snowflake
from snowflake.snowpark.context import get_active_session

# Function to get the active Snowpark session
def get_session():
    return get_active_session()

st.set_page_config(layout="wide")

session = get_session()
TABLE_NAME = "CFG_VW_CONTROL"
COL_1 = "PROGRAM_NAME"
COL_2 = "VIEW_NAME"

st.title(":orange[Cfg View Control]")
st.subheader(":blue[Search for Program or View]")

# --- 1. Search for records ---
with st.form("search_form"):
    search_value = st.text_input("**Enter Value:**")
    search_button = st.form_submit_button(label="Search")

if search_button and search_value:
    try:
        query = f"""
            SELECT
                CFG_VW_CONTROL_ID,
                PROGRAM_NAME,
                VIEW_NAME,
                MIN_DISPLAY_DATE,
                MAX_DISPLAY_DATE,
                COMMENTS,
                USER_STORY,
                UPDATE_DATE
            FROM {TABLE_NAME}
            WHERE {COL_1} ILIKE ? OR {COL_2} ILIKE ?
        """

        search_pattern = f"%{search_value}%"
        df = session.sql(query, params=[search_pattern, search_pattern]).to_pandas()

        if not df.empty:
            st.success(f"Found {len(df)} records.")
            st.session_state["search_results"] = df.copy()
            st.session_state["edited_data"] = df.copy()
        else:
            st.warning("No record found.")
            st.session_state["search_results"] = None
            st.session_state["edited_data"] = None

    except Exception as e:
        st.error(f"Error during search: {e}")

# --- 2. Display and edit records ---
if "search_results" in st.session_state and st.session_state["search_results"] is not None:
    st.subheader(":blue[Edit Records]")

    edited_df = st.data_editor(
        st.session_state["edited_data"],
        num_rows="fixed",
        hide_index=True,
        disabled=["CFG_VW_CONTROL_ID", "PROGRAM_NAME", "VIEW_NAME", "UPDATE_DATE"]
    )

    st.session_state["edited_data"] = edited_df

    update_button = st.button("Update")

    # --- 3. Update the Snowflake table ---
    if update_button:
        try:
            original_df = st.session_state["search_results"]
            updated_df = st.session_state["edited_data"]

            rows_updated = 0

            for i in range(len(updated_df)):
                old_row = original_df.iloc[i]
                new_row = updated_df.iloc[i]

                key_value = new_row["CFG_VW_CONTROL_ID"]

                # Check if editable columns changed
                changed = (
                    old_row["MIN_DISPLAY_DATE"] != new_row["MIN_DISPLAY_DATE"] or
                    old_row["MAX_DISPLAY_DATE"] != new_row["MAX_DISPLAY_DATE"] or
                    old_row["COMMENTS"] != new_row["COMMENTS"] or
                    old_row["USER_STORY"] != new_row["USER_STORY"]
                )

                if changed:
                    update_sql = f"""
                        UPDATE {TABLE_NAME}
                        SET
                            MIN_DISPLAY_DATE = ?,
                            MAX_DISPLAY_DATE = ?,
                            COMMENTS = ?,
                            USER_STORY = ?,
                            UPDATE_DATE = CURRENT_TIMESTAMP()
                        WHERE CFG_VW_CONTROL_ID = ?
                    """

                    session.sql(
                        update_sql,
                        params=[
                            new_row["MIN_DISPLAY_DATE"],
                            new_row["MAX_DISPLAY_DATE"],
                            new_row["COMMENTS"],
                            new_row["USER_STORY"],
                            key_value
                        ]
                    ).collect()

                    rows_updated += 1

            if rows_updated > 0:
                st.success(f"{rows_updated} record(s) successfully updated in CFG_VW_CONTROL table.")

                # Refresh search results after update
                refresh_query = f"""
                    SELECT
                        CFG_VW_CONTROL_ID,
                        PROGRAM_NAME,
                        VIEW_NAME,
                        MIN_DISPLAY_DATE,
                        MAX_DISPLAY_DATE,
                        COMMENTS,
                        USER_STORY,
                        UPDATE_DATE
                    FROM {TABLE_NAME}
                    WHERE {COL_1} ILIKE ? OR {COL_2} ILIKE ?
                """

                search_pattern = f"%{search_value}%"
                refreshed_df = session.sql(
                    refresh_query,
                    params=[search_pattern, search_pattern]
                ).to_pandas()

                st.session_state["search_results"] = refreshed_df.copy()
                st.session_state["edited_data"] = refreshed_df.copy()

            else:
                st.info("No changes detected.")

        except Exception as e:
            st.error(f"Error applying updates: {e}")
