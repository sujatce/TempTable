SELECT
  MIN(ER_DATE) AS MIN_ER_DATE,
  MAX(ER_DATE) AS MAX_ER_DATE,
  COUNT(*)     AS ROWS_CNT
FROM FWRB_PRD_WMIDR_DB.BI_ANALYSIS.FACT_ER_VISITS;


SELECT
  GMPI_ID,
  ER_DATE,
  ER_STATUS,
  ER_CATEGORY,
  HOSPITAL_PROVIDER,
  CLAIM_ID_ER,
  CLAIM_ID_ADMIT,
  CLAIM_ID_OBS
FROM FWRB_PRD_WMIDR_DB.BI_ANALYSIS.FACT_ER_VISITS
ORDER BY ER_DATE DESC
LIMIT 50;
