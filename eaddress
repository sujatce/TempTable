create or replace view ASQN_PRD_MIGRATION_DB.DBO.VW_WM_MEMBER_EMAIL(
	REPORT_MONTH,
	ENTITY_ID,
	MBI,
	MEMBER_ID,
	GMPI_ID,
	MEMBER_LAST_NAME,
	MEMBER_FIRST_NAME,
	MEMBER_EMAIL,
	EMAIL_UPDATE_DATE
) as
select DISTINCT 
  MRM.REPORT_MONTH
  ,EE.ENTITY_ID
    ,DM.MEMBER_MBI AS MBI
    ,DM.MEMBER_ID
    ,DM.GMPI_ID
    ,MRM.MEMBER_LAST_NAME
    ,MRM.MEMBER_FIRST_NAME
    ,EE.EMAILADDRESS AS MEMBER_EMAIL
    ,EE.UPDATEDATE AS EMAIL_UPDATE_DATE
FROM LIG_PRD_MRCS_OH_OUTREACH_SH_DB.MRCS_OH_OUTREACH.TBL_CONTACT_EMAIL EE
    INNER JOIN LIG_PRD_MRCS_OH_OUTREACH_SH_DB.MRCS_OH_OUTREACH.TBL_DEMOGRAPHIC ED
        ON EE.ENTITY_ID = ED.ENTITY_ID
    INNER JOIN FWRB_PRD_WMIDR_DB.BI_ANALYSIS.DIM_MEMBER DM
        ON ED.MBI = DM.MEMBER_MBI
    INNER JOIN FWRB_PRD_WMIDR_DB.BI_ANALYSIS.MEMBER_REPORT_MONTH MRM
        ON DM.MEMBER_ID = MRM.MEMBER_ID
    INNER JOIN ASQN_PRD_MIGRATION_DB.DBO.VW_WM_MEMBER_EMAIL_MBI_MAXUPDATE MU
        ON MU.MBI = ED.MBI
        AND MU.MAX_UPDATE_DATE = EE.UPDATEDATE
where UPPER(EE.EMAIL_INVALID_IND) != 'INVALID'
AND MRM.REPORT_MONTH IN (SELECT MAX(REPORT_MONTH) FROM FWRB_PRD_WMIDR_DB.BI_ANALYSIS.MEMBER_REPORT_MONTH)
and EE.ENTITY_ID NOT IN (SELECT DISTINCT ENTITY_ID 
                            FROM LIG_PRD_MRCS_OH_OUTREACH_SH_DB.MRCS_OH_OUTREACH.TBL_CONSENT_DNC DNE
                            WHERE UPPER(DNE.PREF_CODE) = 'DO_NOT_EMAIL'
                            AND UPPER(SELECTED) = 'Y');
