create or replace view ASQN_PRD_MIGRATION_DB.DBO.VW_WM_UHC_MBR_ADDRESS(
	REPORT_MONTH,
	ENTITY_ID,
	MBI,
	MEMBER_ID,
	GMPI_ID,
	MEMBER_LAST_NAME,
	MEMBER_FIRST_NAME,
	MEMBER_ADDRESS_LINE1,
	MEMBER_ADDRESS_LINE2,
	MEMBER_CITY,
	MEMBER_ZIP,
	MEMBER_STATE,
	MEMBER_COUNTY,
	MEMBER_COUNTRY,
	ADDRESS_TYPE,
	ADDRESS_EFFECTIVE_DATE,
	ADDRESS_END_DATE,
	ADDRESS_UPDATE_DATE
) as
select DISTINCT 
  MRM.REPORT_MONTH
    ,EA.ENTITY_ID
    ,DM.MEMBER_MBI AS MBI
    ,DM.MEMBER_ID
    ,DM.GMPI_ID
    ,MRM.MEMBER_LAST_NAME
    ,MRM.MEMBER_FIRST_NAME
    ,EA.ADDRESSLINE1 AS MEMBER_ADDRESS_LINE1
    ,EA.ADDRESSLINE2 AS MEMBER_ADDRESS_LINE2
    ,EA.CITY AS MEMBER_CITY
    ,EA.POSTALCODE AS MEMBER_ZIP
    ,EA.PROVINCESTATE AS MEMBER_STATE
    ,EA.COUNTY AS MEMBER_COUNTY
    ,EA.COUNTRY AS MEMBER_COUNTRY
    ,EA.ADDRESS_USETYPE AS ADDRESS_TYPE
    ,EA.EFFECTIVEDATE AS ADDRESS_EFFECTIVE_DATE
    ,EA.ENDDATE AS ADDRESS_END_DATE
    ,EA.UPDATEDATE AS ADDRESS_UPDATE_DATE
  FROM LIG_PRD_MRCS_OH_OUTREACH_SH_DB.MRCS_OH_OUTREACH.TBL_CONTACT_ADDRESS EA
    INNER JOIN LIG_PRD_MRCS_OH_OUTREACH_SH_DB.MRCS_OH_OUTREACH.TBL_DEMOGRAPHIC ED
        ON EA.ENTITY_ID = ED.ENTITY_ID
    INNER JOIN FWRB_PRD_WMIDR_DB.BI_ANALYSIS.DIM_MEMBER DM
        ON ED.MBI = DM.MEMBER_MBI
    INNER JOIN FWRB_PRD_WMIDR_DB.BI_ANALYSIS.MEMBER_REPORT_MONTH MRM
        ON DM.MEMBER_ID = MRM.MEMBER_ID
    WHERE MRM.REPORT_MONTH IN (SELECT MAX(REPORT_MONTH) FROM FWRB_PRD_WMIDR_DB.BI_ANALYSIS.MEMBER_REPORT_MONTH)


🔍 If you want more detail (VERY useful)
👉 To actually see the duplicate rows:
SELECT *
FROM LIG_PRD_MRCS_OH_OUTREACH_SH_DB.MRCS_OH_OUTREACH.TBL_CONTACT_ADDRESS EA
WHERE (EA.ENTITY_ID, EA.ADDRESS_USETYPE) IN (
    SELECT
        ENTITY_ID,
        ADDRESS_USETYPE
    FROM LIG_PRD_MRCS_OH_OUTREACH_SH_DB.MRCS_OH_OUTREACH.TBL_CONTACT_ADDRESS
    GROUP BY
        ENTITY_ID,
        ADDRESS_USETYPE
    HAVING COUNT(*) > 1
)
ORDER BY ENTITY_ID, ADDRESS_USETYPE;
⚠️ Important Insight (from your view)
In your view, you used:
SELECT DISTINCT
👉 That may be hiding duplicates, not fixing them
So this check is critical before relying on the view
🚀 Advanced (Best Practice)
If you want to check duplicates based on latest address only, then:
SELECT
    ENTITY_ID,
    ADDRESS_USETYPE,
    COUNT(*) AS ROW_COUNT
FROM (
    SELECT *,
           ROW_NUMBER() OVER (
               PARTITION BY ENTITY_ID, ADDRESS_USETYPE
               ORDER BY UPDATEDATE DESC
           ) AS RN
    FROM LIG_PRD_MRCS_OH_OUTREACH_SH_DB.MRCS_OH_OUTREACH.TBL_CONTACT_ADDRESS
)
GROUP BY ENTITY_ID, ADDRESS_USETYPE
HAVING COUNT(*) > 1;
