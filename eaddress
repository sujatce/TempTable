create or replace secure view ASQN_DEV_ORCHESTRATION_DB.ACCESS.VW_CAMPAIGN_REVOCATIONS(
	REVOCATIONS_ID COMMENT 'Table Primary Key.',
	OMNI_RECORD_ID COMMENT 'Unique identifier assigned to the record within the vendor dialing system.',
	GMPI_ID COMMENT 'WellMed unique member identifier.',
	OMNI_CONTACT_INFO COMMENT 'Member Phone Number associated with the outreach.',
	MEMBER_FIRST_NAME COMMENT 'First name of the member enrolled in the health plan.',
	MEMBER_LAST_NAME COMMENT 'Last name of the member enrolled in the health plan.',
	MEMBER_DATE_OF_BIRTH COMMENT 'Date of birth of the member enrolled in the health plan.',
	CALLING_LIST COMMENT 'Name of the source outreach file or calling list provided to the vendor.',
	OMNI_CMPGN_DESC COMMENT 'Description of the campaign associated with the outreach record.',
	OMNI_CMPGN_DESC2 COMMENT 'Description of the dialer name associated with the outreach record.',
	OMNI_CMPGN_DESC3 COMMENT 'Description of the program name and/or member type associated with the outreach record.',
	OMNI_LOAD_DATE COMMENT 'Date the Campaign was provided with the member list.',
	SOURCE_TABLE_NAME COMMENT 'Target layer table source of the data for traceability.',
	SOURCE_TABLE_ID COMMENT 'Foreign key of the source for traceability.',
	REVOC_RSN COMMENT 'Reason for revocation code.',
	RSN_STATUS_DATE COMMENT 'Timestamp recording of revocation code.',
	FILE_NAME COMMENT 'Name of the file tied to the record.',
	UPDATE_DATE COMMENT 'Timestamp recording when the row was last updated.'
) COMMENT='This view provides a history of South Region Campaign Revocation Files auto-generated on in-flight campaigns when compared to new member DNC preference requests under the TCPA (Telephone Consumer Protection Act). UHC requires outreach lists to be scrubbed for new DNCs a minimum of every 3-4 days.\n\nThe WellMed Central Quality Performance Analytics team manages campaign orchestration through sourcing and storing campaign data for reporting and suppression purposes, to reduce member abrasion, follow enterprise minimum use requirements, and maintain a historical record of member outreach.\n\nThe Telephone Consumer Protection Act (TCPA) was enacted in 1991 to protect consumers from unwanted telephone calls, text messages, and faxes. TCPA places several detailed restrictions such as consent, disclosure, identification, and/or opt-out requirements when initiating auto-dialed calls, artificial, prerecorded voice calls, AI-generated calls, text messages, informational and telemarketing calls and texts, unsolicited fax advertisements, and telephone solicitations. TCPA non-compliance risks penalties of $500-$1,500 per phone call/text (+ attorney fees) paid to the called party and/or civil forfeitures to the U.S. Government up to $10,000 per violation for illegal robocalls.\n\nNOTE: This view represents a historical record of files generated only. Manual processor intervention is required to share revocation files with the outreach vendor.\n'
 as
SELECT
    REVOCATIONS_ID,
	OMNI_RECORD_ID,
	GMPI_ID,
	OMNI_CONTACT_INFO,
	MEMBER_FIRST_NAME,
    MEMBER_LAST_NAME,
	MEMBER_DATE_OF_BIRTH,
	CALLING_LIST,
	OMNI_CMPGN_DESC,
	OMNI_CMPGN_DESC2,
	OMNI_CMPGN_DESC3,
	OMNI_LOAD_DATE,
	SOURCE_TABLE_NAME,
	SOURCE_TABLE_ID,
	REVOC_RSN,
	RSN_STATUS_DATE,
	FILE_NAME,
	UPDATE_DATE 	
FROM
    ASQN_DEV_ORCHESTRATION_DB.DBO.CAMPAIGN_REVOCATIONS
WHERE
    UPDATE_DATE <= (SELECT MAX_DISPLAY_DATE
        FROM ASQN_DEV_CFG_DB.DBO.CFG_VW_CONTROL
        WHERE VIEW_NAME = 'VW_CAMPAIGN_REVOCATIONS')
AND UPDATE_DATE >= (SELECT MIN_DISPLAY_DATE
        FROM ASQN_DEV_CFG_DB.DBO.CFG_VW_CONTROL
        WHERE VIEW_NAME = 'VW_CAMPAIGN_REVOCATIONS');
 
