WITH MRM_LATEST AS
(
    SELECT
        GMPI_ID,
        REPORT_MONTH,
        MBR_ELIG_INSURANCE_COMPANY_ID,
        ROW_NUMBER() OVER
        (
            PARTITION BY GMPI_ID
            ORDER BY REPORT_MONTH DESC
        ) AS RN
    FROM BI_ANALYSIS.dbo.MEMBER_REPORT_MONTH
    WHERE GMPI_ID = 701477579
      AND REPORT_YEAR = 2025
      AND ACTIVE_FLAG = 1
)

SELECT
    MRM.GMPI_ID,
    MRM.REPORT_MONTH,
    MRM.MBR_ELIG_INSURANCE_COMPANY_ID,
    QMT.NUMERATOR_COUNT
FROM MRM_LATEST MRM
LEFT JOIN BI_ANALYSIS.dbo.QM_MEMBER_TOTAL QMT
    ON MRM.GMPI_ID = QMT.GMPI_ID
   AND MRM.REPORT_MONTH = QMT.REPORT_MONTH
   AND QMT.CODE = 'BCS'
WHERE MRM.RN = 1;


SELECT TOP 1
    MRM.GMPI_ID,
    MRM.REPORT_MONTH,
    MRM.MBR_ELIG_INSURANCE_COMPANY_ID,
    QMT.NUMERATOR_COUNT
FROM BI_ANALYSIS.dbo.MEMBER_REPORT_MONTH MRM
LEFT JOIN BI_ANALYSIS.dbo.QM_MEMBER_TOTAL QMT
    ON MRM.GMPI_ID = QMT.GMPI_ID
   AND MRM.REPORT_MONTH = QMT.REPORT_MONTH
   AND QMT.CODE = 'BCS'
WHERE MRM.GMPI_ID = 701477579
  AND MRM.REPORT_YEAR = 2025
  AND MRM.ACTIVE_FLAG = 1
ORDER BY MRM.REPORT_MONTH DESC;

