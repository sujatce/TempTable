FROM ASQN_DEV_ORCHESTRATION_DB.DBO.EPMP_RAW_OLD;

-- CHECKING THE COUNTS

SELECT COUNT(*)
FROM ASQN_DEV_ORCHESTRATION_DB.DBO.EPMP_RAW_OLD;

SELECT COUNT(*)
FROM ASQN_DEV_ARCHIVE_DB.DBO.EPMP_RAW_OLD;

-- CHECKING THE HASH_AGG TO SEE IF THE DATA MATCHED

SELECT
    COUNT(*) AS ROW_COUNT_ORCHESTRATION,
    HASH_AGG(*) AS DATA_HASH_ORCHESTRATION
FROM ASQN_DEV_ORCHESTRATION_DB.DBO.EPMP_RAW_OLD;

