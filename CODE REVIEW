UPDATE ASQN_DEV_VENDOR_DB.DBO.VENDOR_RESPONSE VR
SET VR.KIT_TYPE = LGC.KIT_TYPE,
   VR.UPDATE_DATE=CURRENT_TIMESTAMP,
   VR.UPDATE_USER=CURRENT_USER
FROM ASQN_DEV_VENDOR_DB.DBO.VENDOR_RAW_RESPONSE_LGC LGC
WHERE VR.PROGRAM_NAME = LGC.PROGRAM_NAME
 AND VR.VENDOR_RAW_RESPONSE_ID=LGC.VENDOR_RAW_RESPONSE_ID
 AND VR.VENDOR_NAME = 'LGC';



SELECT DISTINCT KIT_TYPE, PROGRAM_NAME, COUNT(*)
FROM ASQN_DEV_VENDOR_DB.DBO.VENDOR_RESPONSE
WHERE VENDOR_NAME='LGC'
GROUP BY 1,2
ORDER BY 1;













