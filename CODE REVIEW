create or replace view VW_VENDOR_RESPONSE_TABLEAU(
	GMPI_ID,
	MEMBER_FULL_NAME,
	MEMBER_LAST_NAME,
	MEMBER_FIRST_NAME,
	MEMBER_DATE_OF_BIRTH,
	MEMBER_ID,
	MEMBER_MBI,
	MEMBER_FULL_ADDRESS,
	MEMBER_ADDRESS_1,
	MEMBER_CITY,
	MEMBER_STATE,
	MEMBER_ZIP,
	PROVIDER_FULL_NAME,
	PROVIDER_RELATION,
	CLINIC_NAME,
	CLINIC_GROUP_NAME,
	REGION,
	MARKET,
	CONTRACT_ID,
	CONTRACT_PBP,
	CONTRACT_ID_PBP,
	PROGRAM_NAME,
	VENDOR,
	MEASURE,
	TRACKING_ID,
	CAMPAIGN_YEAR,
	CAMPAIGN_QUARTER,
	CAMPAIGN_START_DATE,
	OUTREACH_MODE,
	VENDOR_OBLIGATION_STATUS,
	DATE_OF_STATUS,
	RESULT_RELATED_TO_STATUS,
	ADDITIONAL_RESULTS_1,
	ADDITIONAL_RESULTS_2,
	ADDITIONAL_RESULTS_3,
	ADDITIONAL_RESULTS_4,
	ADDITIONAL_RESULTS_5,
	ADDITIONAL_RESULTS_6,
	KIT_TYPE,
	KIT_SENT,
	KIT_RETURNED,
	CALL_ATTEMPTED,
	CALL_REACHED,
	CALL_NOT_REACHED,
	CALL_UNRESOLVED,
	CALL_SCHEDULED,
	CALL_COMPLETED,
	EXAM_COMPLETED,
	JOIN_1,
	JOIN_2
) as
SELECT
	C.GMPI_ID,
	CONCAT(
        IFF(C.MEMBER_LAST_NAME IS NULL, '', C.MEMBER_LAST_NAME),
        ', ',
        IFF(C.MEMBER_FIRST_NAME IS NULL, '', C.MEMBER_FIRST_NAME)
        ) AS MEMBER_FULL_NAME,
	C.MEMBER_LAST_NAME,
	C.MEMBER_FIRST_NAME,
	C.MEMBER_DATE_OF_BIRTH,
	C.MEMBER_ID,
	C.MEMBER_MBI,
	CONCAT(
        IFF(C.MEMBER_ADDRESS_1 IS NULL, '', C.MEMBER_ADDRESS_1), ' ',
        IFF(C.MEMBER_CITY IS NULL, '', C.MEMBER_CITY), ' ',
        IFF(C.MEMBER_STATE IS NULL, '', C.MEMBER_STATE), ' ',
        IFF(C.MEMBER_ZIP IS NULL, '', C.MEMBER_ZIP)
        ) AS MEMBER_FULL_ADDRESS,
	C.MEMBER_ADDRESS_1,
	C.MEMBER_CITY,
	C.MEMBER_STATE,
	C.MEMBER_ZIP,
	C.PROVIDER_FULL_NAME,
	C.PROVIDER_RELATION,
	C.CLINIC_NAME,
	C.CLINIC_GROUP_NAME,
	C.REGION,
	C.MARKET,
	C.CONTRACT_ID,
	C.CONTRACT_PBP,
	CONCAT(
        IFF(C.CONTRACT_ID IS NULL, '', C.CONTRACT_ID),
        '-',
        IFF(C.CONTRACT_PBP IS NULL, '', C.CONTRACT_PBP)
        ) AS CONTRACT_ID_PBP,
	C.PROGRAM_NAME,
	C.VENDOR,
	CASE WHEN C.PROGRAM_NAME IN ('HEALPROS OMW','VUEPOINT OMW') AND C.MEASURE ='OMW2' THEN 'OMW' ELSE C.MEASURE END AS MEASURE,
	C.TRACKING_ID,
	C.CAMPAIGN_YEAR,
	C.CAMPAIGN_QUARTER,
	C.CAMPAIGN_START_DATE,
	C.OUTREACH_MODE,
	V.VENDOR_OBLIGATION_STATUS,
	V.DATE_OF_STATUS,
	V.RESULT_RELATED_TO_STATUS,
	V.ADDITIONAL_RESULTS_1,
	V.ADDITIONAL_RESULTS_2,
	V.ADDITIONAL_RESULTS_3,
	V.ADDITIONAL_RESULTS_4,
	V.ADDITIONAL_RESULTS_5,
	V.ADDITIONAL_RESULTS_6,
    C.KIT_TYPE,
	CASE WHEN C.OUTREACH_MODE = 'KIT' THEN 1 END AS KIT_SENT,
	V.KIT_RETURNED,
	V.CALL_ATTEMPTED,
	V.CALL_REACHED,
	V.CALL_NOT_REACHED,
	V.CALL_UNRESOLVED,
	V.CALL_SCHEDULED,
	V.CALL_COMPLETED,
	V.EXAM_COMPLETED,
	CASE
		WHEN C.CAMPAIGN_YEAR =2024 AND C.VENDOR IN ('EVICORE','LABCORP','LGC','VUEPOINT') THEN CAST(C.GMPI_ID AS VARCHAR)
		WHEN C.CAMPAIGN_YEAR =2024 AND C.VENDOR ='HEALPROS' THEN C.MEMBER_MBI
		WHEN C.CAMPAIGN_YEAR >2024 THEN CAST(C.GMPI_ID AS VARCHAR)
		END AS JOIN_1,
	CASE
		WHEN C.CAMPAIGN_YEAR =2024 AND C.VENDOR IN ('LABCORP','LGC','VUEPOINT') THEN C.TRACKING_ID
		WHEN C.CAMPAIGN_YEAR >2024 THEN C.TRACKING_ID
		END AS JOIN_2
FROM ASQN_DEV_ORCHESTRATION_DB.DBO.CAMPAIGN_TARGET C
LEFT JOIN ASQN_DEV_VENDOR_DB.dbo.VW_VENDOR_RESPONSE_TABLEAU_PARTITION V ON C.CAMPAIGN_YEAR = V.CAMPAIGN_YEAR
	AND C.PROGRAM_NAME = V.PROGRAM_NAME
	AND V.JOIN_1 =
		CASE
		WHEN C.CAMPAIGN_YEAR =2024 AND C.VENDOR IN ('EVICORE','LABCORP','LGC','VUEPOINT') THEN CAST(C.GMPI_ID AS VARCHAR)
		WHEN C.CAMPAIGN_YEAR =2024 AND C.VENDOR ='HEALPROS' THEN C.MEMBER_MBI
		WHEN C.CAMPAIGN_YEAR >2024 THEN CAST(C.GMPI_ID AS VARCHAR) END
	AND (V.JOIN_2 =
		(CASE
		WHEN C.CAMPAIGN_YEAR =2024 AND C.VENDOR IN ('LABCORP','LGC','VUEPOINT') THEN C.TRACKING_ID
		WHEN C.CAMPAIGN_YEAR >2024 THEN C.TRACKING_ID
		END)
		OR V.JOIN_2 IS NULL)
WHERE
    UPPER(C.BUSINESS_UNIT) = 'VENDOR'
    AND NOT (C.PROGRAM_NAME IN (
	 'EVICORE BCS'
	,'HEALPROS CDCEYE'
	,'LGC CDCA1C'
	,'LGC COL'
	,'LGC KED UACR'
    ,'LGC KED')
  AND C.MEASURE = 'OMW2');
