create or replace view VW_VENDOR_RESPONSE(
	VENDOR_RESPONSE_ID,
	VENDOR_RAW_RESPONSE_ID,
	VENDOR_RAW_RESPONSE_TABLE,
	MBI,
	GMPI_ID,
	MEMBER_NAME,
	MEMBER_DATE_OF_BIRTH,
	PROGRAM_NAME,
	VENDOR_NAME,
	MEASURE,
	OUTREACH_MODE,
	VENDOR_OBLIGATION_STATUS,
	DATE_OF_STATUS,
	RESULT_RELATED_TO_STATUS,
	ADDITIONAL_RESULTS_1,
	ADDITIONAL_RESULTS_2,
	ADDITIONAL_RESULTS_3,
	ADDITIONAL_RESULTS_4,
	ADDITIONAL_RESULTS_5,
	ADDITIONAL_RESULTS_6,
	KIT_TYPE,
	KIT_RETURNED,
	CALL_ATTEMPTED,
	CALL_REACHED,
	CALL_NOT_REACHED,
	CALL_UNRESOLVED,
	CALL_SCHEDULED,
	CALL_COMPLETED,
	EXAM_COMPLETED,
	TRACKING_ID,
	CAMPAIGN_YEAR,
	TABLEAU_FLAG,
	VA_FLAG,
	VARK_FLAG,
	FILE_NAME,
	FILE_TYPE,
	FILE_CREATION_DATE,
	JOIN_1,
	JOIN_2
) as
SELECT
	VR.VENDOR_RESPONSE_ID,
	VR.VENDOR_RAW_RESPONSE_ID,
	VR.VENDOR_RAW_RESPONSE_TABLE,
	VR.MBI,
	VR.GMPI_ID,
	VR.MEMBER_NAME,
	VR.MEMBER_DATE_OF_BIRTH,
	VR.PROGRAM_NAME,
	VR.VENDOR_NAME,
	VR.MEASURE,
	VP.OUTREACH_MODE,
	VR.VENDOR_OBLIGATION_STATUS,
	VR.DATE_OF_STATUS,
	VR.RESULT_RELATED_TO_STATUS,
	VR.ADDITIONAL_RESULTS_1,
	VR.ADDITIONAL_RESULTS_2,
	VR.ADDITIONAL_RESULTS_3,
	VR.ADDITIONAL_RESULTS_4,
	VR.ADDITIONAL_RESULTS_5,
	VR.ADDITIONAL_RESULTS_6,
    VR.KIT_TYPE,
    CASE
        WHEN UPPER(VP.OUTREACH_MODE) = 'KIT' AND UPPER(VR.VENDOR_OBLIGATION_STATUS) = 'OPEN' THEN 0
        WHEN UPPER(VP.OUTREACH_MODE) = 'KIT' AND UPPER(VR.VENDOR_OBLIGATION_STATUS) = 'CLOSED' THEN 1
        END AS KIT_RETURNED,
    CASE VP.OUTREACH_MODE WHEN 'MANUAL_CALL' THEN VD.ATTEMPTED END AS CALL_ATTEMPTED,
    CASE VP.OUTREACH_MODE WHEN 'MANUAL_CALL' THEN VD.REACHED END AS CALL_REACHED,
	CASE VP.OUTREACH_MODE WHEN 'MANUAL_CALL' THEN VD.NOT_REACHED END AS CALL_NOT_REACHED,
	CASE VP.OUTREACH_MODE WHEN 'MANUAL_CALL' THEN VD.UNRESOLVED END AS CALL_UNRESOLVED,
	CASE VP.OUTREACH_MODE WHEN 'MANUAL_CALL' THEN VD.SCHEDULED END AS CALL_SCHEDULED,
    CASE VP.OUTREACH_MODE WHEN 'MANUAL_CALL' THEN VD.COMPLETED END AS CALL_COMPLETED,
	--   ,CASE WHEN UPPER(VP.OUTREACH_MODE) = 'MANUAL_CALL' AND UPPER(VR.VENDOR_NAME) ='HEALPROS' AND UPPER(VENDOR_OBLIGATION_STATUS) = 'OPEN' THEN 0
	-- 		WHEN UPPER(VP.OUTREACH_MODE) = 'MANUAL_CALL' AND UPPER(VR.VENDOR_NAME) ='HEALPROS' AND UPPER(VENDOR_OBLIGATION_STATUS) = 'CLOSED' THEN 1
	-- 		WHEN UPPER(VP.OUTREACH_MODE) = 'MANUAL_CALL' AND UPPER(VR.VENDOR_NAME) !='HEALPROS' THEN COMPLETED
	-- END AS EXAM_COMPLETED
    CASE 
        WHEN UPPER(VP.OUTREACH_MODE) = 'MANUAL_CALL'
            AND UPPER(VR.VENDOR_NAME) = 'HEALPROS' AND UPPER(VR.VENDOR_OBLIGATION_STATUS) = 'OPEN' THEN 0
        WHEN UPPER(VP.OUTREACH_MODE) = 'MANUAL_CALL'
            AND UPPER(VR.VENDOR_NAME) = 'HEALPROS' AND UPPER(VR.VENDOR_OBLIGATION_STATUS) = 'CLOSED' THEN 1
        WHEN UPPER(VP.OUTREACH_MODE) = 'MANUAL_CALL'
            AND UPPER(VR.VENDOR_NAME) != 'HEALPROS' THEN CAST(VD.COMPLETED AS INT)
        END AS EXAM_COMPLETED,
	VR.TRACKING_ID,
	VR.CAMPAIGN_YEAR,
	VP.TABLEAU_FLAG,
	VP.VA_FLAG,
	VP.VARK_FLAG,
	VR.FILE_NAME,
	VR.FILE_TYPE,
	VR.FILE_CREATION_DATE,
    CASE
        WHEN VR.CAMPAIGN_YEAR =2024 AND VR.VENDOR_NAME IN ('EVICORE','LABCORP','LGC','VUEPOINT') THEN CAST(VR.GMPI_ID AS VARCHAR)
        WHEN VR.CAMPAIGN_YEAR =2024 AND VR.VENDOR_NAME ='HEALPROS' THEN VR.MBI
        WHEN VR.CAMPAIGN_YEAR >2024 THEN CAST(VR.GMPI_ID AS VARCHAR)
        END AS JOIN_1,
    CASE
        WHEN VR.CAMPAIGN_YEAR =2024 AND VR.VENDOR_NAME IN ('LABCORP','LGC','VUEPOINT') THEN VR.TRACKING_ID
        WHEN VR.CAMPAIGN_YEAR >2024 THEN VR.TRACKING_ID
        END AS JOIN_2
  FROM ASQN_DEV_VENDOR_DB.DBO.VENDOR_RESPONSE VR
  INNER JOIN ASQN_DEV_VENDOR_DB.DBO.VENDOR_PROGRAM VP ON VR.PROGRAM_NAME = VP.PROGRAM_NAME
    AND VR.VENDOR_NAME = VP.VENDOR_NAME
	AND VR.MEASURE = VP.MEASURE
  LEFT JOIN ASQN_DEV_VENDOR_DB.DBO.VENDOR_DISPOSITION VD ON VR.VENDOR_NAME = VD.VENDOR_NAME
    AND VR.RESULT_RELATED_TO_STATUS = VD.DISPOSITION_NAME;


