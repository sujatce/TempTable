SELECT
    ENTITY_ID,
    MEMBER_PHONE,
    PHONE_TYPE,
    PRIMARY_PHONE_INDICATOR,
    COUNT(*) AS ROW_COUNT,
    COUNT(DISTINCT PHONE_UPDATE_DATE) AS DISTINCT_UPDATE_DATES,
    MIN(PHONE_UPDATE_DATE) AS MIN_UPDATE_DATE,
    MAX(PHONE_UPDATE_DATE) AS MAX_UPDATE_DATE
FROM ASQN_PRD_MIGRATION_DB.DBO.VW_WM_MEMBER_PHONE
GROUP BY
    ENTITY_ID,
    MEMBER_PHONE,
    PHONE_TYPE,
    PRIMARY_PHONE_INDICATOR
HAVING 
    COUNT(*) > 1
    AND COUNT(DISTINCT PHONE_UPDATE_DATE) > 1
ORDER BY ROW_COUNT DESC;
