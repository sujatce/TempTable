    SELECT
   ENTITY_ID,
   MEMBER_PHONE,
   PHONE_TYPE,
   COUNT(*) AS ROW_COUNT,
   COUNT(PHONE_UPDATE_DATE) AS PHONE_UPDATE_DATES,
FROM ASQN_PRD_MIGRATION_DB.DBO.VW_WM_MEMBER_PHONE
GROUP BY
   ENTITY_ID,
   MEMBER_PHONE,
   PHONE_TYPE
HAVING 
  COUNT(*) > 1 AND
 COUNT(PHONE_UPDATE_DATE) > 1
ORDER BY ROW_COUNT DESC;
