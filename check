USE SECONDARY ROLES ALL;

SELECT
    MIN(LAB_DATE) AS MIN_LAB_DATE,
    MAX(LAB_DATE) AS MAX_LAB_DATE,
    COUNT(*) AS ROWS_CNT
FROM FWRB_PRD_WMIDR_DB.BI_ANALYSIS.FACT_LAB
WHERE LAB_DATE >= DATEADD(DAY, -60, CURRENT_DATE);

SELECT DISTINCT PROCEDURE_CODE
FROM FWRB_PRD_WMIDR_DB.BI_ANALYSIS.FACT_LAB
WHERE LAB_DATE >= DATEADD(DAY, -60, CURRENT_DATE)
  AND PROCEDURE_CODE IS NOT NULL
ORDER BY PROCEDURE_CODE;

SELECT DISTINCT LOINC_CODE
FROM FWRB_PRD_WMIDR_DB.BI_ANALYSIS.FACT_LAB
WHERE LAB_DATE >= DATEADD(DAY, -60, CURRENT_DATE)
  AND LOINC_CODE IS NOT NULL
ORDER BY LOINC_CODE;


SELECT
    PROCEDURE_CODE,
    NAME_TEST,
    NAME_PANEL,
    COUNT(*) AS CNT
FROM FWRB_PRD_WMIDR_DB.BI_ANALYSIS.FACT_LAB
WHERE LAB_DATE >= DATEADD(DAY, -60, CURRENT_DATE)
  AND PROCEDURE_CODE IS NOT NULL
GROUP BY PROCEDURE_CODE, NAME_TEST, NAME_PANEL
ORDER BY CNT DESC, PROCEDURE_CODE;

SELECT
    LOINC_CODE,
    NAME_TEST,
    NAME_PANEL,
    COUNT(*) AS CNT
FROM FWRB_PRD_WMIDR_DB.BI_ANALYSIS.FACT_LAB
WHERE LAB_DATE >= DATEADD(DAY, -60, CURRENT_DATE)
  AND LOINC_CODE IS NOT NULL
GROUP BY LOINC_CODE, NAME_TEST, NAME_PANEL
ORDER BY CNT DESC, LOINC_CODE;

SELECT DISTINCT NAME_TEST
FROM FWRB_PRD_WMIDR_DB.BI_ANALYSIS.FACT_LAB
WHERE LAB_DATE >= DATEADD(DAY, -60, CURRENT_DATE)
  AND NAME_TEST IS NOT NULL
ORDER BY NAME_TEST;


SELECT DISTINCT NAME_PANEL
FROM FWRB_PRD_WMIDR_DB.BI_ANALYSIS.FACT_LAB
WHERE LAB_DATE >= DATEADD(DAY, -60, CURRENT_DATE)
  AND NAME_PANEL IS NOT NULL
ORDER BY NAME_PANEL;


SELECT
    PROCEDURE_CODE,
    LOINC_CODE,
    NAME_TEST,
    NAME_PANEL,
    COUNT(*) AS CNT
FROM FWRB_PRD_WMIDR_DB.BI_ANALYSIS.FACT_LAB
WHERE LAB_DATE >= DATEADD(DAY, -60, CURRENT_DATE)
  AND (PROCEDURE_CODE IS NOT NULL OR LOINC_CODE IS NOT NULL)
GROUP BY PROCEDURE_CODE, LOINC_CODE, NAME_TEST, NAME_PANEL
ORDER BY CNT DESC;
