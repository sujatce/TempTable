USE SECONDARY ROLES ALL;

create or replace secure view ASQN_DEV_ORCHESTRATION_DB.ACCESS.VW_WM_NEW_TO_THERAPY_2025(
	RPT_MO_KEY COMMENT 'This field captures the Year and Month of when the record was created.',
	REPORTDATE COMMENT 'Last Empanelment Date.',
	HCONTRACT COMMENT 'Contract Number, typically beginning with H and followed by 4 digit number.',
	CDO COMMENT 'Care Delivery Organization - is a legal entity that delivers healthcare services and products.',
	CDO_SUBGROUP COMMENT 'Sub division of CDOs in a region.',
	YEAR_DOS COMMENT 'Year of Date of Service - Captures the Year for which data is relevant.',
	MONTH_DOS COMMENT 'Month of Date of Service- Captures the Month of the year for which data is relevant.',
	BYY COMMENT 'Best Year Yet. This is a Flag that is associated to OPTUM population (mostly global risk), sample value - 1.',
	MGMT_TYPE COMMENT 'Identifies if a member belongs to OptumCare or Optum at Home. Sample values - OC, OC_OAH.',
	PBP COMMENT 'Plan Benefit Package-A set of benefits for a defined MA or PDP service area. ',
	PCP_NPI COMMENT 'Primary Care Provider National Provider Identifier.',
	ENTY_ID COMMENT 'Enity ID-Numeric identifier that identifies a CDO. Sample values - 30063, 30010.',
	PCP_TIN COMMENT 'Primary Care Provider National Provider Identifier Tax ID Number.',
	EMP_STATUS COMMENT 'This field identifies if PCP is Employed/Contracted/Affiliated.Example values - E, C, A.',
	RISK_TYPE COMMENT 'This field captures the financial cost structure associated with member. Example values - GLOBAL, FFS.',
	MEASURE_YEAR COMMENT 'It is the period of time when patients are receiving their screenings, filling prescriptions and responding to surveys.                                        The measurement period is literally the calendar year Jan. 1 - Dec. 31.',
	CONTRACT_PBP COMMENT 'Concatenated value of HContract and PBP.',
	SUPER_CDO COMMENT 'Historical reference to CDO for CA region, place holder for that data.',
	SUPER_CDO_SUBGROUP COMMENT 'Historical reference to CDO for CA region, place holder for that data.',
	MAD_FILLS_2Y COMMENT 'Number of MAD medication fills in the past 2 years.',
	MAD_LATEST_FILL_DATE COMMENT 'Last fill date for MAD medication.',
	MAD_DAYS_SINCE_LAST_FILL COMMENT 'Days since MAD medication was last filled.',
	MAD_NEW_TO_THERAPY COMMENT 'New to Therapy members for MAD are identified as having a first fill of a medication adherence medication in the last 30-days and showing no history of being a part of the measure within the past 2 years.',
	MAD_FILLS_180D COMMENT 'Number of MAD medication fills in the past 180 days.',
	MAD_NTT_RESTART COMMENT 'New to Therapy restart members for MAD are identified as having a first fill of a medication adherence medicationin the last 30-days and has a history of being a part of the measure within the past 2 years but no fills within the past 6 months.',
	MAD_LATEST_FILL_DAYS_SUPPLY COMMENT 'Days supply covered in the last fill for MAD medication.',
	MAD_LATEST_FILL_QUANTITY COMMENT 'Quantity of the drugs bought in last fill for MAD medication.',
	MAC_FILLS_2Y COMMENT 'Number of MAC medication fills in the past 2 years.',
	MAC_LATEST_FILL_DATE COMMENT 'Last fill date for MAC medication.',
	MAC_DAYS_SINCE_LAST_FILL COMMENT 'Days since MAC medication was last filled.',
	MAC_NEW_TO_THERAPY COMMENT 'New to Therapy members for MAC are identified as having a first fill of a medication adherence medication in the last 30-days and showing no history of being a part of the measure within the past 2 years.',
	MAC_FILLS_180D COMMENT 'Number of MAC medication fills in the past 180 days.',
	MAC_NTT_RESTART COMMENT 'New to Therapy restart members for MAC are identified as having a first fill of a medication adherence medication in the last 30-days and has a history of being a part of the measure within the past 2 years but no fills within the past 6 months.',
	MAC_LATEST_FILL_DAYS_SUPPLY COMMENT 'Days supply covered in the last fill for MAC medication.',
	MAC_LATEST_FILL_QUANTITY COMMENT 'Quantity of the drugs bought in last fill for MAC medication.',
	MAH_FILLS_2Y COMMENT 'Number of MAH medication fills in the past 2 years.',
	MAH_LATEST_FILL_DATE COMMENT 'Last fill date for MAH medication.',
	MAH_DAYS_SINCE_LAST_FILL COMMENT 'Days since MAH medication was last filled.',
	MAH_NEW_TO_THERAPY COMMENT 'New to Therapy members for MAH are identified as having a first fill of a medication adherence medication in the last 30-days and showing no history of being a part of the measure within the past 2 years.',
	MAH_FILLS_180D COMMENT 'Number of MAH medication fills in the past 180 days.',
	MAH_NTT_RESTART COMMENT 'New to Therapy restart members for MAH are identified as having a first fill of a medication adherence medication in the last 30-days and has a history of being a part of the measure within the past 2 years but no fills within the past 6 months.',
	MAH_LATEST_FILL_DAYS_SUPPLY COMMENT 'Days supply covered in the last fill for MAH medication.',
	MAH_LATEST_FILL_QUANTITY COMMENT 'Quantity of the drugs bought in last fill for MAH medication.',
	GMPI_ID COMMENT 'Member identifier internal to Wellmed.',
	MBI COMMENT 'Medicare Beneficiary Identifier.',
	ENCRYPT COMMENT 'Flag to Identify if member is Offshore/Onshore.',
	REPORT_DATE COMMENT 'Date when the process runs and creates the output.',
	OC_FLAG COMMENT 'OptumCare flag, used for identifying OptumCare members',
	EMR_FLAG COMMENT 'Flag to determine a Home and Community member.',
	HC_OC_COMANAGED_FLAG COMMENT 'This flag indicates if a member is co-managed by Home & Community (HC) and OptumCare (OC).',
	ENTERPRISE_INDV_ID COMMENT 'Enterprise Individual ID.',
	CLAIMS_REFRESH_DATE COMMENT 'Refresh Date of the claim.',
	MAC_NTT_GENERIC COMMENT 'The generic component associated with the therapy, if member is new to therapy for MAC medication.',
	MAD_NTT_GENERIC COMMENT 'The generic component associated with the therapy, if member is new to therapy for MAD medication.',
	MAH_NTT_GENERIC COMMENT 'The generic component associated with the therapy, if member is new to therapy for MAH medication.',
	MAC_NTT_MED_NAME COMMENT 'The drug name associated with the therapy, if member is new to therapy for MAC medication.',
	MAD_NTT_MED_NAME COMMENT 'The drug name associated with the therapy, if member is new to therapy for MAD medication.',
	MAH_NTT_MED_NAME COMMENT 'The drug name associated with the therapy, if member is new to therapy for MAH medication.',
	PROCESS_LOG_ID COMMENT 'DB specific field.',
	LOAD_DATETIME COMMENT 'Date and Time when the record was loaded into this table.',
	RECORD_ID COMMENT 'This is a DB field. It captures Id assigned to each inserted record in the table.',
	PATIENT_MISMATCH COMMENT 'Flag to indicate if the member has a matching record in BI Analysis.'
) COMMENT='This dataset contains information around Optum Home and Community membership, MAD, MAC and MAH refill dates and Optum health membership indicator.\nIt enhances existing New To Therapy calculations for the Optum Home and Community delegated members in the Medicare and Retirement (M&R) population.\n\nData is used to identify members who are receiving a new prescription for a MAC/MAD/MAH measure medication where they either have no prior claim history of that medication, or have no evidence of a paid claim within the past 6 months.'
 as
SELECT RPT_MO_KEY, 
       REPORTDATE, 
       HCONTRACT, 
       CDO, 
       CDO_SUBGROUP, 
       YEAR_DOS, 
       MONTH_DOS, 
       BYY, 
       MGMT_TYPE, 
       PBP, 
       PCP_NPI, 
       ENTY_ID, 
       PCP_TIN, 
       EMP_STATUS, 
       RISK_TYPE, 
       MEASURE_YEAR, 
       CONTRACT_PBP, 
       SUPER_CDO, 
       SUPER_CDO_SUBGROUP, 
       MAD_FILLS_2Y, 
       MAD_LATEST_FILL_DATE, 
       MAD_DAYS_SINCE_LAST_FILL, 
       MAD_NEW_TO_THERAPY, 
       MAD_FILLS_180D, 
       MAD_NTT_RESTART, 
       MAD_LATEST_FILL_DAYS_SUPPLY, 
       MAD_LATEST_FILL_QUANTITY, 
       MAC_FILLS_2Y, 
       MAC_LATEST_FILL_DATE, 
       MAC_DAYS_SINCE_LAST_FILL, 
       MAC_NEW_TO_THERAPY,
       MAC_FILLS_180D, 
       MAC_NTT_RESTART, 
       MAC_LATEST_FILL_DAYS_SUPPLY, 
       MAC_LATEST_FILL_QUANTITY, 
       MAH_FILLS_2Y, 
       MAH_LATEST_FILL_DATE, 
       MAH_DAYS_SINCE_LAST_FILL, 
       MAH_NEW_TO_THERAPY,
       MAH_FILLS_180D, 
       MAH_NTT_RESTART, 
       MAH_LATEST_FILL_DAYS_SUPPLY, 
       MAH_LATEST_FILL_QUANTITY, 
       gmp.GMPI_ID,  --not available
       MBI, 
       ENCRYPT, 
       REPORT_DATE, 
       OC_FLAG, 
       EMR_FLAG, 
       HC_OC_COMANAGED_FLAG, 
       ENTERPRISE_INDV_ID, 
       CLAIMS_REFRESH_DATE, 
       MAC_NTT_GENERIC, 
       MAD_NTT_GENERIC, 
       MAH_NTT_GENERIC, 
       MAC_NTT_MED_NAME, 
       MAD_NTT_MED_NAME, 
       MAH_NTT_MED_NAME, 
       PROCESS_LOG_ID, 
       LOAD_DATETIME, 
       RECORD_ID, 
       CASE WHEN gmp.gmpi_id is not null THEN 0
            ELSE 1
       END AS PATIENT_MISMATCH 
FROM ASQN_DEV_ORCHESTRATION_DB.DBO.NEW_TO_THERAPY_ARCHIVE_2025 ntt
 LEFT JOIN (
            select distinct m.gmpi_id, m.member_mbi
            from 
            	(
            	select gmpi_id, member_mbi, Row_Number() 
            	  over (
            		     partition by dm.member_mbi 
            		     order by dm.dw_insert_date Desc, dm.dw_update_date Desc
            		   ) as rn 
            	 from fwrb_prd_wmidr_db.bi_analysis.dim_member dm
            	where member_mbi is not NULL 
            	  and active_flag = 1 
            	  and dm.data_entity = 'Wellmed'
                  order by gmpi_id
            	) as m 
            where m.rn = 1
           ) gmp on ntt.mbi = gmp.member_mbi
WHERE 1 = 1   
  AND UPDATE_DATE <= (SELECT MAX_DISPLAY_DATE 
                    FROM ASQN_DEV_CFG_DB.DBO.CFG_VW_CONTROL
                    WHERE VIEW_NAME = 'VW_WM_NEW_TO_THERAPY_2025')
  AND UPDATE_DATE >= (SELECT MIN_DISPLAY_DATE 
                    FROM ASQN_DEV_CFG_DB.DBO.CFG_VW_CONTROL
                    WHERE VIEW_NAME = 'VW_WM_NEW_TO_THERAPY_2025')
;
                    

