create or replace view ASQN_PRD_ORCHESTRATION_DB.REPORT.VW_WM_UHC_MBR_PREF_RPT(
	REPORT_MONTH,
	ENTITY_ID,
	MBI,
	MEMBER_ID,
	GMPI_ID,
	MEMBER_LAST_NAME,
	MEMBER_FIRST_NAME,
	DO_NOT_MAIL,
	DNM_UPDATE_DATE,
	DO_NOT_EMAIL,
	DNE_UPDATE_DATE,
	DO_NOT_CALL,
	DNC_UPDATE_DATE
) as
select 
     MRM.REPORT_MONTH
    ,CD.ENTITY_ID
    ,DM.MEMBER_MBI AS MBI
    ,DM.MEMBER_ID
    ,DM.GMPI_ID
    ,MRM.MEMBER_LAST_NAME
    ,MRM.MEMBER_FIRST_NAME
    ,MAX(CASE WHEN CD.PREF_CODE = 'Do_Not_Mail' THEN CD.SELECTED END) AS DO_NOT_MAIL
    ,MAX(CASE WHEN CD.PREF_CODE = 'Do_Not_Mail' THEN CD.AUDITDATETIME END) AS DNM_UPDATE_DATE
    ,MAX(CASE WHEN CD.PREF_CODE = 'Do_Not_Email' THEN CD.SELECTED END) AS DO_NOT_EMAIL
    ,MAX(CASE WHEN CD.PREF_CODE = 'Do_Not_Email' THEN CD.AUDITDATETIME END) AS DNE_UPDATE_DATE
    ,MAX(CASE WHEN CD.PREF_CODE = 'Do_Not_Call' THEN CD.SELECTED END) AS DO_NOT_CALL
    ,MAX(CASE WHEN CD.PREF_CODE = 'Do_Not_Call' THEN CD.AUDITDATETIME END) AS DNC_UPDATE_DATE
  FROM
  (SELECT * FROM LIG_PRD_MRCS_OH_OUTREACH_SH_DB.MRCS_OH_OUTREACH.TBL_CONSENT_DNC 
   WHERE PREF_CODE IN ('Do_Not_Call','Do_Not_Mail','Do_Not_Email')
   QUALIFY ROW_NUMBER() OVER (
   PARTITION BY ENTITY_ID,PREF_CODE
   ORDER BY UPDATEDATE DESC) = 1 
  ) CD
    INNER JOIN LIG_PRD_MRCS_OH_OUTREACH_SH_DB.MRCS_OH_OUTREACH.TBL_DEMOGRAPHIC ED
        ON CD.ENTITY_ID = ED.ENTITY_ID
    INNER JOIN FWRB_PRD_WMIDR_DB.BI_ANALYSIS.DIM_MEMBER DM
        ON ED.MBI = DM.MEMBER_MBI
    INNER JOIN 
    (SELECT * FROM FWRB_PRD_WMIDR_DB.BI_ANALYSIS.MEMBER_REPORT_MONTH 
    QUALIFY ROW_NUMBER() OVER (PARTITION BY MEMBER_ID
    ORDER BY REPORT_MONTH DESC) =1
    )MRM 
        ON DM.MEMBER_ID = MRM.MEMBER_ID
    GROUP BY 
     MRM.REPORT_MONTH
    ,CD.ENTITY_ID
    ,DM.MEMBER_MBI 
    ,DM.MEMBER_ID
    ,DM.GMPI_ID
    ,MRM.MEMBER_LAST_NAME
    ,MRM.MEMBER_FIRST_NAME;




