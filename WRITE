select distinct [e].[GMPI_ID],
	[e].[MEMBER_LAST_NAME],
	[e].[MEMBER_FIRST_NAME],
	[e].[MEMBER_EMAIL],
	[e].[MBI] 
from [ORCHESTRATION].[dbo].[EPMP_EMAIL] [e] 
where [e].[MEMBER_LAST_NAME] is not NULL 
	and [e].[MEMBER_FIRST_NAME] is not NULL 
	and [e].[MEMBER_EMAIL] is not NULL 
	and LTrim(RTrim([e].[MEMBER_LAST_NAME])) <> '' 
	and LTrim(RTrim([e].[MEMBER_FIRST_NAME])) <> '' 
	and LTrim(RTrim([e].[MEMBER_EMAIL])) <> ''
