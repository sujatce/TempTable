create or replace view ASQN_PRD_ORCHESTRATION_DB.REPORT.VW_WM_UHC_MBR_EMAIL(
	REPORT_MONTH COMMENT 'Month of the member empanelment in BI Analysis MRM stored in YYYY-MM-DD format',
	ENTITY_ID COMMENT 'A unique number used by the enterprise to identify an individual person',
	MBI COMMENT 'Member Beneficiary Identifier issued by CMS to identify Medicare beneficiaries',
