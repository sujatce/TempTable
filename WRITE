SELECT
    SMS_OPT_IN_RAW_ID,
    MEMBER_LAST_NAME,
    MEMBER_FIRST_NAME,
    MEMBER_ADDRESS_1,
    MEMBER_CITY,
    MEMBER_STATE,
    MEMBER_ZIP,
    MEMBER_PHONE,
    MEMBER_EMAIL,
    SMS_CONSENT,
    SMS_CONSENT_DATE,
    CONSENT_TERMS,
    FILE_NAME,
    FILE_CREATION_DATE
FROM ASQN_DEV_ORCHSTRATION_DBO.SMS_OPT_IN_RAW
WHERE MEMBER_LAST_NAME IS NOT NULL
  AND MEMBER_FIRST_NAME IS NOT NULL
  AND MEMBER_EMAIL IS NOT NULL;
