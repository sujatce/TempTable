SELECT
    V.MBI,
    V.MEMBER_EMAIL,
    V.EMAIL_UPDATE_DATE,
    S.MAX_UPDATE_DATE
FROM ASQN_PRD_ORCHESTRATION_DB.REPORT.VW_WM_UHC_MBR_EMAIL V
JOIN (
    SELECT
        ED.MBI,
        MAX(EE.UPDATEDATE) AS MAX_UPDATE_DATE
    FROM LIG_PRD_MRCS_OH_OUTREACH_SH_DB.MRCS_OH_OUTREACH.TBL_CONTACT_EMAIL EE
    INNER JOIN LIG_PRD_MRCS_OH_OUTREACH_SH_DB.MRCS_OH_OUTREACH.TBL_DEMOGRAPHIC ED
        ON EE.ENTITY_ID = ED.ENTITY_ID
    WHERE UPPER(EE.EMAIL_INVALID_IND) != 'INVALID'
    GROUP BY ED.MBI
) S
ON V.MBI = S.MBI
WHERE V.EMAIL_UPDATE_DATE != S.MAX_UPDATE_DATE;
