 WITH latest_mrm AS (
    SELECT *
 
 FROM (
        SELECT 
            mrm.*,
            ROW_NUMBER() OVER (
                PARTITION BY mrm.member_id
                ORDER BY mrm.dw_update_date DESC
            ) AS rn_mrm
        FROM FWRB_PRD_WMIDR_DB.BI_ANALYSIS.member_report_month mrm
        WHERE mrm.report_month = (
            SELECT MAX(report_month)
            FROM FWRB_PRD_WMIDR_DB.BI_ANALYSIS.member_report_month mrm
        )
    ) b
    WHERE b.rn_mrm = 1
)
SELECT
    MRM.GMPI_ID,
    MRM.MEMBER_LAST_NAME,
    MRM.MEMBER_FIRST_NAME,
    MRM.MBR_DATE_OF_BIRTH,
    MRM.MBR_GENDER,
    MRM.MEMBER_ID,
    DM.MEMBER_MBI,
    DMA.MEMBER_PHONE AS MEMBER_PHONE,
    HMO.ELIGIBLE_FLAG AS ELIGIBILITY_FLAG,
    MRM.RISK_POOL_CODE,
    MRM.SRF_STATUS,
    MRM.PROVIDER_ID,
    CONCAT(DP.PROVIDER_FIRST_NAME, ' ', DP.PROVIDER_LAST_NAME) AS PROVIDER_FULL_NAME,
    DPA.CONTACT_PHONE AS PROVIDER_PHONE,
    DP.NPI_ID,

    CASE
        WHEN DC.CLINIC_RELATION = 'Affiliated' THEN 'Affiliated'
        WHEN MRM.OWNED_FLAG = 0 THEN 'Contracted'
        WHEN MRM.OWNED_FLAG = 1 THEN 'Owned'
        ELSE ''
    END AS PROVIDER_RELATION,

    MRM.CLINIC_ID,
    MRM.CLINIC_NAME,
    MRM.CLINIC_GROUP_ID,
    MRM.CLINIC_GROUP_NAME,
    MRM.REGION_ID,
    MRM.REGION,
    MRM.MARKET_ID,
    MRM.MARKET,

    CASE 
        WHEN MRM.MBR_ELIG_INSURANCE_COMPANY_FULL_NAME IN (
            'United Community & State Texas',
            'United Facets Lite',
            'United of Florida',
            'United of Greater Texas',
            'United of Texas',
            'Cosmos United Lite'
        ) THEN 'UnitedHealthcare'
        ELSE MRM.MBR_ELIG_INSURANCE_COMPANY_FULL_NAME
    END AS MBR_ELIG_INSURANCE_COMPANY_FULL_NAME,

    MRM.MBR_ELIG_INSURANCE_COMPANY,
    MRM.MBR_ELIG_INSURANCE_COMPANY_ID,
    MRM.CONTRACT_ID,
    MRM.CONTRACT_PBP,
    MRM.MBR_BENEFIT_PLAN_CODE,
    MRM.BENEFIT_PLAN_DESCRIPTION,
    MRM.DATA_ENTITY,
    DM.MEMBER_LANGUAGE,
    'WELLMED' AS CDO,
    'WELLMED' AS BUSINESS_SEGMENT,
    MRM.REPORT_MONTH AS MRM_REPORT_MONTH

FROM  latest_mrm mrm

LEFT JOIN FWRB_PRD_WMIDR_DB.BI_ANALYSIS.DIM_PROVIDER DP 
    ON MRM.PROVIDER_ID = DP.PROVIDER_ID

LEFT JOIN FWRB_PRD_WMIDR_DB.BI_ANALYSIS.DIM_PROVIDER_ADDRESS DPA 
    ON DP.PROVIDER_ID = DPA.PROVIDER_ID 
    AND DPA.ACTIVE_FLAG = 1 
    AND DPA.PROVIDER_ADDRESS_PRIMARY_FLAG = 1 

LEFT JOIN FWRB_PRD_WMIDR_DB.BI_ANALYSIS.DIM_CLINIC DC 
    ON MRM.CLINIC_ID = DC.CLINIC_ID 
    AND DC.ACTIVE_FLAG = 1 

LEFT JOIN FWRB_PRD_WMIDR_DB.BI_ANALYSIS.HIER_MEMBER_OPER HMO 
    ON MRM.REPORT_MONTH = HMO.HIER_MONTH 
    AND MRM.MEMBER_ID = HMO.MEMBER_ID 
    AND MRM.GMPI_ID = HMO.GMPI_ID 
    AND HMO.ACTIVE_FLAG = 1 

LEFT JOIN FWRB_PRD_WMIDR_DB.BI_ANALYSIS.DIM_MEMBER DM 
    ON MRM.GMPI_ID = DM.GMPI_ID 

LEFT JOIN FWRB_PRD_WMIDR_DB.BI_ANALYSIS.DIM_MEMBER_ADDRESS DMA 
    ON DMA.MEMBER_ID = MRM.MEMBER_ID 
    AND DMA.ACTIVE_FLAG = 1 

WHERE 
    MRM.MEMBER_LAST_NAME IS NOT NULL
    AND MRM.MEMBER_FIRST_NAME IS NOT NULL
    AND MRM.MBR_DATE_OF_BIRTH IS NOT NULL
    AND MRM.MBR_GENDER IS NOT NULL
    AND DM.MEMBER_MBI IS NOT NULL
    AND MRM.REGION IN ('Florida', 'Greater Texas', 'Houston', 'North Texas')
    AND MRM.CONTRACT_ID IN (
        'H0609','H1278','H2406','H4514','H4527','H5322','H4513','H0062',
        'H0174','H4506','H5294','H0028','H4461','H1045','H1889','H2509',
        'H5420','R0759','H1032','H1036','H5216','H5427','H5594'
    )
    AND MRM.MBR_BENEFIT_PLAN_CODE NOT IN (
        '2025H0609822164','2025H0609822199','2025H0609822207',
        '2026H0609822164','2026H0609822199','2026H0609822207'
    )
    AND MRM.DATA_ENTITY = 'Wellmed'
    AND DM.MEMBER_LANGUAGE IN ('English', 'Spanish')
    AND MRM.REPORT_MONTH = '2026-06-01'
    AND DP.PROVIDER_FIRST_NAME IS NOT NULL
    AND MRM.ACTIVE_FLAG = 1
    AND MRM.IS_HOSPICE_FLAG = 0
    AND MRM.LTI_FLAG = 0
    AND MRM.ESRD_FLAG = 0
    AND DM.ACTIVE_FLAG = 1
    AND MRM.GMPI_ID = '12345678'

ORDER BY MRM.GMPI_ID;biz
